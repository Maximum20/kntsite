---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero.astro";
---

<Layout title="Відділення променевої терапії">
  <main class="grid gap-20 mt-16 text-slate-800">
    <Hero />
    
    <!-- Переваги -->
    <section class="container mx-auto px-5">
      <div class="mt-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-center tracking-tight">Сучасні технології лікування</h2>
        <p class="text-lg mt-4 text-slate-600 text-center max-w-xl mx-auto font-medium">
          Використовуємо передове обладнання Elekta для досягнення найкращих результатів у боротьбі з хворобою.
        </p>
      </div>
      
      <div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16 text-center">
        <div>
           <div class="rounded-full bg-blue-100 p-4 w-16 h-16 mx-auto flex items-center justify-center text-blue-600 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight">Висока точність</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">Субміліметровий контроль дози опромінення.</p>
        </div>
        <div>
           <div class="rounded-full bg-green-100 p-4 w-16 h-16 mx-auto flex items-center justify-center text-green-600 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight">Швидкість VMAT</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">Сеанс триває 2-5 хвилин, що комфортно для пацієнта.</p>
        </div>
        <div>
           <div class="rounded-full bg-purple-100 p-4 w-16 h-16 mx-auto flex items-center justify-center text-purple-600 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12H15M12 9V15M12 2L2 7L12 22L22 7L12 2Z" /></svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight">Безпека</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">Максимальний захист здорових тканин та органів.</p>
        </div>
      </div>
    </section>

    <!-- Етапи лікування -->
    <section class="bg-slate-50 py-16 px-5 border-y border-slate-200">
      <div class="container mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 tracking-tight text-slate-900">Як проходить лікування?</h2>
        <div class="grid md:grid-cols-4 gap-8">
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-20">01</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight">Консультація</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Огляд провідним лікарем та детальний аналіз КТ/МРТ знімків.</p>
          </div>
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-20">02</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight">КТ-розмітка</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Виготовлення фіксуючих засобів та топометрична підготовка.</p>
          </div>
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-20">03</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight">Планування</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Робота медичних фізиків над створенням 3D-плану лікування.</p>
          </div>
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-20">04</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight">Опромінення</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Курс сеансів на лінійному прискорювачі Elekta Versa HD.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- СЕКЦІЯ КОНТАКТІВ (Куди скролить кнопка) -->
    <section id="contacts" class="container mx-auto px-5 py-20 scroll-mt-24">
      <div class="bg-slate-900 rounded-[2rem] p-10 md:p-16 text-white shadow-2xl relative overflow-hidden">
        <!-- Декор на фоні -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 rounded-full blur-[120px] opacity-20 -mr-32 -mt-32"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold mb-12 tracking-tighter">Наші контакти</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
            <!-- Колонна 1: Телефони -->
            <div class="flex flex-col gap-6">
              <span class="text-blue-400 font-bold uppercase text-xs tracking-widest">Реєстратура</span>
              <div class="flex flex-col gap-4 text-xl md:text-2xl font-bold tracking-tight">
                <a href="tel:+380567207901" class="hover:text-blue-400 transition">(056) 720-79-01</a>
                <a href="tel:+380662904491" class="hover:text-blue-400 transition">(066) 290-44-91</a>
                <a href="tel:+380939585567" class="hover:text-blue-400 transition">(093) 958-55-67</a>
                <a href="tel:+380680015515" class="hover:text-blue-400 transition">(068) 001-55-15</a>
              </div>
            </div>

            <!-- Колонна 2: Адреса та пошта -->
            <div class="flex flex-col gap-6">
              <span class="text-blue-400 font-bold uppercase text-xs tracking-widest">Адреса та пошта</span>
              <div class="space-y-4">
                <a href="mailto:kz-kod-dor@ukr.net" class="text-lg md:text-xl font-bold hover:text-blue-400 transition block break-all">
                  kz-kod-dor@ukr.net
                </a>
                <p class="text-slate-400 leading-relaxed font-medium">
                  м. Дніпро, вул. Космічна, 21<br/>
                  КНП "Дніпровський обласний клінічний онкологічний диспансер" ДОР
                </p>
              </div>
            </div>

            <!-- Колонна 3: Соцмережі -->
            <div class="flex flex-col gap-6">
              <span class="text-blue-400 font-bold uppercase text-xs tracking-widest">Ми в мережі</span>
              <div class="flex flex-wrap gap-5">
                <!-- Facebook -->
                <a href="https://www.facebook.com/kz.kod.dor" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
                </a>
                <!-- Telegram -->
                <a href="https://t.me/dokod_dp" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-sky-500 transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.665 3.717l-17.73 6.837c-1.213.486-1.203 1.163-.223 1.467l4.55 1.42 10.532-6.645c.498-.303.953-.14.578.192l-8.533 7.707-.33 4.955c.483 0 .697-.223.967-.483l2.325-2.26 4.837 3.57c.89.49 1.53.24 1.752-.823l3.17-14.937c.325-1.3-.5-1.894-1.352-1.51z"/></svg>
                </a>
                <!-- TikTok (Fixed) -->
                <a href="https://www.tiktok.com/@dokod_dp" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-white hover:text-black transition-all">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 448 512"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
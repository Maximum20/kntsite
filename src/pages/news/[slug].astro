---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// 1. Генеруємо шляхи для всіх новин
export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

// 2. Отримуємо дані конкретної новини
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <article class="max-w-4xl mx-auto px-5 py-20">
    <a href="/#news" class="inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 mb-8 transition-colors">
      ← Назад до новин
    </a>

    {entry.data.image && (
      <div class="rounded-[2rem] overflow-hidden mb-12 shadow-2xl">
        <Image 
          src={entry.data.image} 
          alt={entry.data.title} 
          class="w-full h-auto object-cover"
        />
      </div>
    )}

    <div class="mb-10">
      <time class="text-blue-600 font-bold uppercase text-sm tracking-widest">
        {entry.data.date.toLocaleDateString('uk-UA')}
      </time>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mt-4 leading-tight">
        {entry.data.title}
      </h1>
      <p class="text-xl text-slate-500 mt-6 leading-relaxed font-medium">
        {entry.data.description}
      </p>
    </div>

    <hr class="border-slate-100 mb-10" />

    <div class="prose prose-slate prose-lg max-w-none 
      prose-headings:font-bold prose-headings:text-slate-900 
      prose-p:leading-relaxed prose-p:text-slate-600
      prose-img:rounded-2xl">
      <Content />
    </div>
  </article>
</Layout>
---
import { SEO } from "astro-seo";
// ПРАВКА 1: Змінюємо шляхи з "@components" на відносні "../components"
import Footer from "../components/footer.astro";
import Navbar from "../components/navbar/navbar.astro";

// ПРАВКА 2: Шрифт Bricolage Grotesque також вимагає підключення CSS-файлу
import "@fontsource-variable/inter/index.css";
import '@fontsource-variable/bricolage-grotesque/index.css';


import "../styles/global.css";



export interface Props {
  title: string;
}

// ПРАВКА 3: Прибираємо зайвий символ "^"
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

// ПРАВКА 4: Змінюємо назву за замовчуванням з "Astroship" на назву вашого відділення
const makeTitle = title
  ? title + " | " + "Відділення променевої терапії"
  : "Відділення променевої терапії - Сучасне лікування раку";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
	<meta name="robots" content="noindex, nofollow" />

    <meta name="viewport" content="width=device-width" />
	
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={makeTitle}
      // ПРАВКА 5: Оновлюємо опис для Google та соціальних мереж
      description="Офіційний сайт відділення променевої терапії у Дніпрі. Сучасні методи лікування IMRT, VMAT. Інформація для пацієнтів та колег."
      canonical={canonicalURL}
      twitter={{
        creator: "@",
        site: "@",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Логотип Відділення променевої терапії",
        },
      }}
    />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
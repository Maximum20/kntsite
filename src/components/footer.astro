---
// Footer.astro
---

<footer id="footer-section" class="mt-20 border-t border-slate-200 py-16 px-5 relative overflow-hidden">
  <!-- Плаваючі геометричні фігури на фоні -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="floating-shape bg-blue-400/5" style="width: 60px; height: 60px; left: 20%; animation-delay: 0s; animation-duration: 20s;"></div>
    <div class="floating-shape bg-slate-300/5" style="width: 40px; height: 40px; left: 38%; animation-delay: 2s; animation-duration: 15s;"></div>
    <div class="floating-shape bg-blue-300/5" style="width: 80px; height: 80px; left: 56%; animation-delay: 4s; animation-duration: 25s;"></div>
    <div class="floating-shape bg-slate-400/5" style="width: 30px; height: 30px; left: 74%; animation-delay: 1s; animation-duration: 18s;"></div>
    <div class="floating-shape bg-blue-500/5" style="width: 50px; height: 50px; left: 92%; animation-delay: 3s; animation-duration: 22s;"></div>
  </div>

  <!-- Інтерактивний gradient що слідкує за мишкою -->
  <div id="mouse-gradient" class="absolute w-96 h-96 rounded-full pointer-events-none opacity-0 transition-opacity duration-300"></div>

  <div class="max-w-screen-xl mx-auto relative">
    <div class="flex flex-col items-center">
      <!-- Логотип -->
      <div class="mb-8 logo-container">
        <div class="logo-wrapper">
          <img
            src="/src/assets/full-logo.png"
            alt="Логотип"
            class="h-16 md:h-20 w-auto object-contain drop-shadow-lg"
          />
        </div>
      </div>

      <!-- Текст -->
      <div class="text-center max-w-3xl fade-in">
        <p class="text-[10px] md:text-xs uppercase tracking-wide text-slate-400 font-bold mb-3 letter-spacing-animation">
          Дніпровська обласна рада
        </p>

        <p class="text-sm md:text-base text-slate-600 font-medium leading-relaxed mb-2">
          КНТ «Дніпровський обласний клінічний онкологічний диспансер»
        </p>

        <div class="relative inline-block title-hover-container">
          <p class="text-base md:text-lg font-semibold bg-gradient-to-r from-blue-600 via-blue-500 to-blue-600 bg-clip-text text-transparent relative z-10">
            Відділення променевої терапії №1 з блоком реабілітації
          </p>
          <div class="title-hover-bg absolute -inset-2 bg-gradient-to-r from-blue-400/10 via-transparent to-blue-400/10 rounded-lg -z-10 opacity-0 transition-opacity duration-300"></div>
        </div>
      </div>

      <!-- Анімована хвиля з кружечків -->
      <div class="mt-12 flex gap-2">
        <div class="wave-dot" style="animation-delay: 0s;"></div>
        <div class="wave-dot" style="animation-delay: 0.2s;"></div>
        <div class="wave-dot" style="animation-delay: 0.4s;"></div>
        <div class="wave-dot" style="animation-delay: 0.6s;"></div>
        <div class="wave-dot" style="animation-delay: 0.8s;"></div>
        <div class="wave-dot" style="animation-delay: 1s;"></div>
        <div class="wave-dot" style="animation-delay: 1.2s;"></div>
      </div>

      <!-- Копірайт -->
      <div class="mt-8 text-center relative fade-in-delayed">
        <p class="text-xs text-slate-400 relative">
          <span>&copy; {new Date().getFullYear()} Всі права захищені.</span>
        </p>
        
        <!-- Декоративні лінії -->
        <div class="absolute left-1/2 -translate-x-1/2 -bottom-4 flex gap-1">
          <div class="line-expand h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent" style="animation-delay: 0s;"></div>
          <div class="line-expand h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent" style="animation-delay: 0.1s;"></div>
          <div class="line-expand h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent" style="animation-delay: 0.2s;"></div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Плаваючі фігури */
  @keyframes float-shape {
    0% {
      transform: translateY(-100%) translateX(0) rotate(0deg);
    }
    50% {
      transform: translateY(100%) translateX(100px) rotate(180deg);
    }
    100% {
      transform: translateY(300%) translateX(0) rotate(360deg);
    }
  }

  .floating-shape {
    position: absolute;
    border-radius: 50%;
    backdrop-filter: blur(2px);
    top: 50%;
    animation: float-shape linear infinite;
  }

  /* Хвиля з точок */
  @keyframes wave-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.3;
    }
    50% {
      transform: scale(1.5);
      opacity: 1;
    }
  }

  .wave-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(to right, #3b82f6, #2563eb);
    animation: wave-pulse 2s ease-in-out infinite;
  }

  /* Логотип */
  .logo-wrapper {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo-container:hover .logo-wrapper {
    transform: scale(1.05);
    animation: logo-wiggle 0.5s ease-in-out;
  }

  @keyframes logo-wiggle {
    0%, 100% { transform: scale(1.05) rotate(0deg); }
    25% { transform: scale(1.05) rotate(-5deg); }
    75% { transform: scale(1.05) rotate(5deg); }
  }

  /* Letter spacing анімація */
  .letter-spacing-animation {
    animation: letter-spacing-in 1s ease-out forwards;
  }

  @keyframes letter-spacing-in {
    from {
      letter-spacing: 0.5em;
      opacity: 0;
    }
    to {
      letter-spacing: 0.2em;
      opacity: 1;
    }
  }

  /* Fade in */
  .fade-in {
    animation: fade-in 0.6s ease-out 0.2s both;
  }

  .fade-in-delayed {
    animation: fade-in 0.6s ease-out 1s both;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Підсвічування заголовка */
  .title-hover-container:hover .title-hover-bg {
    opacity: 1;
  }

  .title-hover-container:hover p {
    transform: scale(1.02);
    transition: transform 0.3s ease;
  }

  /* Лінії що розгортаються */
  @keyframes line-expand {
    from {
      width: 0;
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .line-expand:nth-child(1) {
    animation: line-expand 0.8s ease-out 1.2s both;
    width: 20px;
  }

  .line-expand:nth-child(2) {
    animation: line-expand 0.8s ease-out 1.3s both;
    width: 30px;
  }

  .line-expand:nth-child(3) {
    animation: line-expand 0.8s ease-out 1.4s both;
    width: 40px;
  }

  /* Градієнт для миші */
  #mouse-gradient {
    background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
    transition: left 0.2s ease-out, top 0.2s ease-out;
  }

  #footer-section:hover #mouse-gradient {
    opacity: 1;
  }
</style>

<script>
  // Mouse tracking gradient
  const footer = document.getElementById('footer-section');
  const gradient = document.getElementById('mouse-gradient');

  if (footer && gradient) {
    footer.addEventListener('mousemove', (e) => {
      const rect = footer.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      gradient.style.left = `${x - 192}px`;
      gradient.style.top = `${y - 192}px`;
    });
  }

  // Parallax для логотипа
  const logoContainer = document.querySelector('.logo-container');
  
  if (footer && logoContainer) {
    footer.addEventListener('mousemove', (e) => {
      const rect = footer.getBoundingClientRect();
      const y = e.clientY - rect.top;
      const logoWrapper = logoContainer.querySelector('.logo-wrapper') as HTMLElement;
      
      if (logoWrapper) {
        logoWrapper.style.transform = `translateY(${y * 0.02}px)`;
      }
    });
  }
</script>
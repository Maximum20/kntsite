---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero.astro";
import News from "../components/news.astro";
import { Icon } from "astro-icon/components";

const departments = [
{
  id: "home",
  title: "Променева терапія",
  image: "/hero/raddepartment.jpg", // Шлях до фото головної
  subtitle: "У Дніпрі",
  description: "Ми створили цей простір, щоб зробити складні технології зрозумілими. Тут ви знайдете повну інформацію про наше обладнання, методи лікування та кожен крок вашого шляху до одужання.",
  features: [
    { 
      title: "Експертність", 
      desc: "Команда медичних фізиків та онкологів з досвідом понад 15 років.", 
      icon: "bx:bxs-graduation", 
      color: "text-blue-600", 
      bg: "bg-blue-100" 
    },
    { 
      title: "Технології Elekta", 
      desc: "Лікування на обладнанні світового рівня з субміліметровою точністю.", 
      icon: "bx:bxs-graduation", 
      color: "text-cyan-600", 
      bg: "bg-cyan-100" 
    },
    { 
      title: "Турбота", 
      desc: "Супровід та підтримка пацієнта на всіх етапах променевої терапії.", 
      icon: "bx:bxs-heart", 
      color: "text-red-600", 
      bg: "bg-red-100" 
    }
  ]
},
  {
    id: "linac",
    title: "Лінійний прискорювач",
    image: "/hero/main_page.jpg", // Шлях до фото головної
    subtitle: "Elekta",
    description: "Найсучасніша система у Дніпрі, що дозволяє реалізувати методики IMRT та VMAT з субміліметровою точністю під контролем Brainlab.",
    features: [
      { title: "Висока точність", desc: "Субміліметровий контроль підведення дози.", icon: "bx:bxs-badge-check", color: "text-blue-600", bg: "bg-blue-100" },
      { title: "Швидкість VMAT", desc: "Сеанс триває 2-5 хвилин — максимально комфортно.", icon: "bx:bxs-zap", color: "text-green-600", bg: "bg-green-100" },
      { title: "Безпека", desc: "Максимальний захист здорових тканин та органів.", icon: "bx:bxs-shield-alt-2", color: "text-purple-600", bg: "bg-purple-100" }
    ]
  },
  {
    id: "gamma",
    title: "Телегамматерапія",
    image: "/hero/gamma.jpg", 
    subtitle: "Cobalt-60",
    description: "Класичний та надійний метод дистанційного опромінення для лікування глибоко розташованих пухлин.",
    features: [
      { title: "Надійність", desc: "Стабільні та перевірені результати.", icon: "bx:bxs-lock-alt", color: "text-blue-600", bg: "bg-blue-100" },
      { title: "Глибока доза", desc: "Ефективне лікування внутрішніх зон.", icon: "bx:bxs-layer", color: "text-cyan-600", bg: "bg-cyan-100" },
      { title: "Доступність", desc: "Швидкий старт лікування без очікування.", icon: "bx:bxs-time-five", color: "text-slate-600", bg: "bg-slate-100" }
    ]
  },
  {
    id: "brachy",
    title: "Брахітерапія",
    image: "/hero/brachy.png",
    subtitle: "Cobalt-60",
    description: "Контактна терапія, що дозволяє підвести екстремально високу дозу прямо всередину пухлини.",
    features: [
      { title: "Локальна дія", desc: "Діє безпосередньо на вогнище хвороби.", icon: "bx:bxs-bullseye", color: "text-red-600", bg: "bg-red-100" },
      { title: "Захист органів", desc: "Опромінення не зачіпає сусідні органи.", icon: "bx:bxs-leaf", color: "text-green-600", bg: "bg-green-100" },
      { title: "Результат", desc: "Високий відсоток повного одужання.", icon: "bx:bxs-star", color: "text-yellow-600", bg: "bg-yellow-100" }
    ]
  },
  {
    id: "nearfocus",
    title: "Рентген-терапія",
    image: "/hero/nearfocus.jpg",
    subtitle: "Лікування пухлин шкіри",
    description: "Амбулаторне лікування базаліом та новоутворень шкіри без хірургічних розрізів та наркозу.",
    features: [
      { title: "Без операції", desc: "Лікування без розрізів та крові.", icon: "bx:bxs-smile", color: "text-blue-600", bg: "bg-blue-100" },
      { title: "Естетика", desc: "Відсутність рубців після курсу.", icon: "bx:bxs-face", color: "text-pink-600", bg: "bg-pink-100" },
      { title: "Комфорт", desc: "Сеанс займає лише кілька хвилин.", icon: "bx:bxs-timer", color: "text-cyan-600", bg: "bg-cyan-100" }
    ]
  },
  {
    id: "ct",
    title: "КТ-розмітка",
    image: "/hero/ct.jpg",
    subtitle: "Підготовка до лікування",
    description: "Створення персоналізованої 3D-моделі пацієнта для ідеального розрахунку напрямків променів.",
    features: [
      { title: "3D Модель", desc: "Точне просторове планування мішені.", icon: "bx:bxs-cube-alt", color: "text-indigo-600", bg: "bg-indigo-100" },
      { title: "Аналіз", desc: "Врахування кожного міліметра анатомії.", icon: "bx:bxs-microscope", color: "text-blue-600", bg: "bg-blue-100" },
      { title: "Персоналізація", desc: "Індивідуальні термопластичні маски.", icon: "bx:bxs-user-pin", color: "text-slate-600", bg: "bg-slate-100" }
    ]
  }
];
---

<Layout title="Відділення променевої терапії">
  <main class="font-sans relative">
    
    <div id="dynamic-zone" class="transition-all duration-500 pt-4 md:pt-6">
      <Hero />

      <section class="container mx-auto px-5 mt-12 md:mt-16">
        <div class="text-center mb-12">
          <h2 id="tech-title" class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 leading-tight">Сучасні технології лікування</h2>
          <p id="tech-desc" class="text-lg mt-4 text-slate-600 max-w-2xl mx-auto font-medium leading-relaxed italic">
            {departments[0].description}
          </p>
        </div>
        
        <div id="tech-grid" class="grid sm:grid-cols-2 md:grid-cols-3 gap-12 text-center">
          {departments[0].features.map(f => (
            <div class="feature-card animate-in">
               <div class={`rounded-full ${f.bg} p-4 w-16 h-16 mx-auto flex items-center justify-center ${f.color} shadow-sm border border-white/50`}>
                 <Icon name={f.icon} class="w-8 h-8" />
               </div>
               <h3 class="font-bold text-xl mt-4 tracking-tight text-slate-900">{f.title}</h3>
               <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>
    </div>

    <section class="bg-slate-50 py-16 px-5 border-y border-slate-200 mt-24">
      <div class="container mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 tracking-tight text-slate-900">Як проходить лікування?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 text-left">
          {[
            { n: "01", t: "Консультація", d: "Огляд лікарем та аналіз КТ/МРТ знімків." },
            { n: "02", t: "КТ-розмітка", d: "Топометрична підготовка та фіксація." },
            { n: "03", t: "Контуринг", d: "Визначення точних меж пухлини та органів." },
            { n: "04", t: "Планування", d: "Робота фізиків над оптимальним 3D-планом." },
            { n: "05", t: "Опромінення", d: "Курс сеансів на Elekta Versa HD." }
          ].map((step) => (
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
              <div class="text-blue-600 font-black text-4xl mb-4 opacity-40">{step.n}</div>
              <h4 class="font-bold text-lg mb-2 tracking-tight text-blue-900">{step.t}</h4>
              <p class="text-sm text-slate-600 leading-relaxed font-medium">{step.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="contacts" class="container mx-auto px-5 py-20 scroll-mt-48">
      <div class="bg-slate-900 rounded-[2.5rem] p-8 md:p-16 text-white shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 rounded-full blur-[120px] opacity-20 -mr-32 -mt-32"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold mb-12 tracking-tighter">Наші контакти</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="flex flex-col gap-6">
              <span class="text-blue-400 font-bold uppercase text-xs tracking-widest">Реєстратура</span>
              <div class="flex flex-col gap-3 text-xl md:text-2xl font-bold tracking-tight">
                <a href="tel:+380567207901" class="hover:text-blue-400 transition-colors">(056) 720-79-01</a>
                <a href="tel:+380662904491" class="hover:text-blue-400 transition-colors">(066) 290-44-91</a>
                <a href="tel:+380939585567" class="hover:text-blue-400 transition-colors">(093) 958-55-67</a>
                <a href="tel:+380680015515" class="hover:text-blue-400 transition-colors">(068) 001-55-15</a>
              </div>
            </div>
            <div class="flex flex-col gap-6 md:border-x md:border-slate-800 md:px-10">
              <span class="text-blue-400 font-bold uppercase text-xs tracking-widest">Адреса та пошта</span>
              <div class="space-y-4">
                <a href="mailto:linac_olt1@ukr.net" class="text-xl font-bold hover:text-blue-400 block break-all">linac_olt1@ukr.net</a>
                <a href="http://googleusercontent.com/maps.google.com/3" target="_blank" class="group block">
                  <p class="text-slate-400 font-medium group-hover:text-blue-400 transition-colors">
                    м. Дніпро, вул. Космічна, 21<br/>КНТ "ДОКОД" ДОР
                  </p>
                  <span class="inline-flex items-center gap-1 text-[10px] text-blue-500 font-bold uppercase mt-2 group-hover:translate-x-1 transition-all">
                    <Icon name="bx:map" class="w-3 h-3" /> Дивитись на карті
                  </span>
                </a>
              </div>
            </div>
            <div class="flex flex-col gap-6">
              <span class="text-blue-400 font-bold uppercase text-xs tracking-widest">Ми в мережі</span>
              <div class="flex flex-wrap gap-4">
                <a href="https://t.me/dokod_dp" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-sky-500 transition-all text-white"><Icon name="bx:bxl-telegram" class="w-6 h-6" /></a>
                <a href="https://www.facebook.com/kz.kod.dor" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-all text-white"><Icon name="bx:bxl-facebook" class="w-6 h-6" /></a>
                <a href="https://www.instagram.com/dokod.dp/" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-pink-600 transition-all text-white"><Icon name="bx:bxl-instagram" class="w-6 h-6" /></a>
                <a href="https://www.youtube.com/@DOKOD_DP" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-red-600 transition-all text-white"><Icon name="bx:bxl-youtube" class="w-6 h-6" /></a>
                <a href="https://www.tiktok.com/@dokod.dp" target="_blank" class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-black transition-all text-white"><Icon name="bx:bxl-tiktok" class="w-6 h-6" /></a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <News />
  </main>
</Layout>

<script define:vars={{ departments }}>
  const buttons = document.querySelectorAll('.dept-btn');
  const logoTrigger = document.querySelector('.logo-home-trigger');
  const dynamicZone = document.getElementById('dynamic-zone');

  // Твій об'єкт з іконками
  const iconMap = {
    'bx:bxs-badge-check': '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>',
    'bx:bxs-zap': '<path d="M7 2v11h3v9l7-12h-4l4-8z"/>',
    'bx:bxs-shield-alt-2': '<path d="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3zm0 10.91l-4-4 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>',
    'bx:bxs-lock-alt': '<path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/>',
    'bx:bxs-layer': '<path d="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27-7.38 5.74zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16z"/>',
    'bx:bxs-time-five': '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 11h-4v-2h2V8h2v5z"/>',
    'bx:bxs-bullseye': '<circle cx="12" cy="12" r="3"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>',
    'bx:bxs-leaf': '<path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66c.34-.85.74-1.66 1.14-2.43a15.82 15.82 0 0 1 12.06-2.06c.09-.34.18-.68.27-1.02a16.12 16.12 0 0 0-9.84-18.49c.04.59.13 1.19.27 1.79A13.88 13.88 0 0 0 17 8z"/>',
    'bx:bxs-star': '<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>',
    'bx:bxs-smile': '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5s.67 1.5 1.5 1.5zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>',
    'bx:bxs-face': '<path d="M9 11.75a1.25 1.25 0 1 0 0-2.5 1.25 1.25 0 0 0 0 2.5zm6 0a1.25 1.25 0 1 0 0-2.5 1.25 1.25 0 0 0 0 2.5z"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-2.5c-2.33 0-4.31-1.46-5.11-3.5h10.22c-.8 2.04-2.78 3.5-5.11 3.5z"/>',
    'bx:bxs-timer': '<path d="M13 3h-2v2h2V3zm4.83 2.59l-1.42-1.42-1.41 1.41 1.42 1.42 1.41-1.41zM7 11.5c0-2.48 2.02-4.5 4.5-4.5s4.5 2.02 4.5 4.5-2.02 4.5-4.5 4.5-4.5-2.02-4.5-4.5zm11.59-3.09l1.42-1.42-1.41-1.41-1.42 1.42 1.41 1.41zM11 19v2h2v-2h-2zm-7.59-3.41l1.41 1.41 1.42-1.42-1.41-1.41-1.42 1.42zM4 11.5h2v-2H4v2zm13.41 4.09l1.41 1.41 1.42-1.42-1.41-1.41-1.42 1.42z"/>',
    'bx:bxs-cube-alt': '<path d="M21 16.5c0 .38-.21.71-.53.88l-7.97 4.41c-.31.17-.69.17-1 0l-7.97-4.41c-.32-.17-.53-.5-.53-.88V7.5c0-.38.21-.71.53-.88l7.97-4.41c.31-.17.69-.17 1 0l7.97 4.41c.32.17.53.5.53.88v9z"/>',
    'bx:bxs-microscope': '<path d="M19.16 15.11l-1.42-1.42a4.44 4.44 0 0 0 .51-2c0-2.48-2.02-4.5-4.5-4.5s-4.5 2.02-4.5 4.5 2.02 4.5 4.5 4.5a4.44 4.44 0 0 0 2-.51l1.42 1.42a7.48 7.48 0 0 1-5.67 2.4c-4.14 0-7.5-3.36-7.5-7.5S7.36 5 11.5 5a7.48 7.48 0 0 1 5.67 2.4l2.5-2.5L21 6.31l-1.84 8.8z"/>',
    'bx:bxs-user-pin': '<path d="M12 2C8.14 2 5 5.14 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.86-3.14-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>',
    'bx:bxs-heart': '<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>',
    'bx:bxs-graduation': '<path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM3.89 9.5l8.11 4.42 8.11-4.42-8.11-4.42-8.11 4.42zM12 15.5l-6-3.27V17c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2v-4.77l-6 3.27z"/>'
  };

  function updateContent(targetId) {
    const data = departments.find(d => d.id === targetId);
    if (!data) return;

    // Ховаємо
    dynamicZone.style.opacity = '0';
    dynamicZone.style.transform = 'translateY(10px)';

    setTimeout(() => {
      // 1. ОНОВЛЮЄМО КАРТИНКИ
      const heroImages = document.querySelectorAll('.hero-dynamic-img');
      heroImages.forEach(img => {
        if (data.image) {
          img.src = data.image;
        }
      });

      // 2. ОНОВЛЮЄМО ТЕКСТИ
      const h1 = document.querySelector('h1');
      if (h1) h1.innerHTML = `${data.title} <br/> <span class="text-blue-600">${data.subtitle || ''}</span>`;
      
      const heroP = document.querySelector('h1 + div + p') || document.querySelector('h1 + p');
      if (heroP) heroP.textContent = data.description;

      const tTitle = document.getElementById('tech-title');
      const tDesc = document.getElementById('tech-desc');
      const tGrid = document.getElementById('tech-grid');

      if (tTitle) {
        tTitle.textContent = targetId === 'home' ? "Наші переваги та можливості" : data.title;
      }
      if (tDesc) tDesc.textContent = data.description;

      if (tGrid) {
        tGrid.innerHTML = data.features.map(f => `
          <div class="animate-in">
             <div class="rounded-full ${f.bg} p-4 w-16 h-16 mx-auto flex items-center justify-center ${f.color} shadow-sm border border-white/50">
               <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">${iconMap[f.icon] || ''}</svg>
             </div>
             <h3 class="font-bold text-xl mt-4 tracking-tight text-slate-900">${f.title}</h3>
             <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">${f.desc}</p>
          </div>
        `).join('');
      }

      // Показуємо
      dynamicZone.style.opacity = '1';
      dynamicZone.style.transform = 'translateY(0)';
    }, 300);
  }

  // Кліки по кнопках
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-blue-600', 'text-white', 'shadow-lg');
        b.classList.add('text-slate-600');
      });
      btn.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
      btn.classList.remove('text-slate-600');
      updateContent(btn.dataset.target);
    });
  });

  // Клік по лого
  logoTrigger?.addEventListener('click', (e) => {
    e.preventDefault();
    buttons.forEach(b => {
      b.classList.remove('active', 'bg-blue-600', 'text-white', 'shadow-lg');
      b.classList.add('text-slate-600');
    });
    updateContent('home');
  });

  // Старт

---
// src/components/ContentBlocks.astro
// Мікро-компоненти для використання всередині accordion
import { Icon } from "astro-icon/components";

const { type = "", items = [], title = "", icon = "", text = "", variant = "default" } = Astro.props;
---

{/* СПИСОК З ІКОНКАМИ ТА HOVER */}
{type === 'icon-list' && (
  <ul class="space-y-3 my-6 not-prose">
    {items.map((item: any, idx: number) => (
      <li class="flex items-start gap-3 p-3 rounded-2xl hover:bg-blue-50 transition-all duration-300 group cursor-default" style={`animation-delay: ${idx * 50}ms`}>
        <div class="flex-shrink-0 w-8 h-8 rounded-xl bg-gradient-to-br from-blue-600 to-blue-700 flex items-center justify-center shadow-lg shadow-blue-600/20 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300">
          <Icon name="bx:check" class="w-5 h-5 text-white" />
        </div>
        <span class="text-slate-700 leading-relaxed pt-0.5 flex-1">{item}</span>
      </li>
    ))}
  </ul>
)}

{/* NUMBERED LIST З ВЕЛИКИМИ НОМЕРАМИ */}
{type === 'numbered-list' && (
  <ol class="space-y-4 my-6 not-prose">
    {items.map((item: any, idx: number) => (
      <li class="flex gap-4 group">
        <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-purple-600 flex items-center justify-center text-white font-black text-lg shadow-lg group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
          {idx + 1}
        </div>
        <div class="flex-1 pt-1">
          <p class="text-slate-700 leading-relaxed">{item}</p>
        </div>
      </li>
    ))}
  </ol>
)}

{/* КАРТКИ В СІТЦІ (МОБІЛЬНІ - 1 КОЛОНКА, ДЕСКТОП - 2) */}
{type === 'card-grid' && (
  <div class="grid sm:grid-cols-2 gap-4 my-6 not-prose">
    {items.map((item: any, idx: number) => (
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 to-purple-600/5 rounded-2xl rotate-1 scale-105 group-hover:scale-110 group-hover:-rotate-1 transition-all duration-300"></div>
        <div class="relative bg-white border-2 border-slate-200 rounded-2xl p-5 hover:border-blue-300 hover:shadow-lg transition-all" style={`animation-delay: ${idx * 100}ms`}>
          {item.icon && (
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-blue-700 flex items-center justify-center text-xl mb-3 shadow-md group-hover:scale-110 group-hover:rotate-12 transition-all">
              <span class="grayscale brightness-[3]">{item.icon}</span>
            </div>
          )}
          {item.title && <h4 class="font-black text-lg text-slate-800 mb-2">{item.title}</h4>}
          <p class="text-slate-600 text-sm leading-relaxed">{item.text}</p>
        </div>
      </div>
    ))}
  </div>
)}

{/* HIGHLIGHT BOX - ВИДІЛЕНИЙ БЛОК */}
{type === 'highlight' && (
  <div class={`my-6 p-5 sm:p-6 rounded-2xl border-l-4 ${
    variant === 'info' ? 'bg-blue-50 border-blue-600' :
    variant === 'success' ? 'bg-emerald-50 border-emerald-600' :
    variant === 'warning' ? 'bg-amber-50 border-amber-600' :
    variant === 'danger' ? 'bg-red-50 border-red-600' :
    'bg-slate-50 border-slate-600'
  } not-prose group hover:shadow-lg transition-all`}>
    
    {/* Шапка: Іконка + Заголовок (в один рядок) */}
    <div class="flex items-center gap-3 mb-3">
      {icon && (
        <div class={`flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center text-2xl ${
          variant === 'info' ? 'bg-blue-100' :
          variant === 'success' ? 'bg-emerald-100' :
          variant === 'warning' ? 'bg-amber-100' :
          variant === 'danger' ? 'bg-red-100' :
          'bg-slate-100'
        } group-hover:scale-110 group-hover:rotate-12 transition-all`}>
          {icon}
        </div>
      )}
      {title && <h4 class="font-black text-lg text-slate-800">{title}</h4>}
    </div>

    {/* Текст: тепер він не затиснутий у колонку, а йде під низ на всю ширину */}
    <div class="text-slate-700 text-sm sm:text-base leading-relaxed">
      <slot />
    </div>
  </div>
)}

{/* EXPANDABLE СЕКЦІЯ (ACCORDION В ACCORDION) */}
{type === 'expandable' && (
  <details class="my-4 bg-white border-2 border-slate-200 rounded-xl overflow-hidden group/exp hover:border-blue-300 transition-all not-prose">
    <summary class="flex items-center justify-between p-4 cursor-pointer list-none hover:bg-slate-50 transition-all">
      <div class="flex items-center gap-3">
        {icon && <span class="text-xl">{icon}</span>}
        <span class="font-bold text-slate-800">{title}</span>
      </div>
      <Icon name="bx:chevron-down" class="w-5 h-5 text-slate-500 group-open/exp:rotate-180 transition-transform" />
    </summary>
    <div class="p-4 pt-2 text-sm text-slate-600 leading-relaxed border-t border-slate-100">
      <slot />
    </div>
  </details>
)}

{/* COMPARISON TABLE - ПОРІВНЯЛЬНА ТАБЛИЦЯ (МОБІЛЬНА ВЕРСІЯ - КАРТКИ) */}
{type === 'comparison-table' && (
  <div class="my-6 not-prose">
    {/* DESKTOP VERSION */}
    <div class="hidden sm:grid sm:grid-cols-2 gap-4">
      {items.map((item: any) => (
        <div class="bg-white border-2 border-slate-200 rounded-2xl p-5 hover:border-blue-300 hover:shadow-lg transition-all">
          <h4 class="font-black text-lg text-slate-800 mb-3 flex items-center gap-2">
            {item.icon && <span class="text-2xl">{item.icon}</span>}
            {item.title}
          </h4>
          <ul class="space-y-2">
            {item.points && item.points.map((point: string) => (
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <Icon name="bx:check-circle" class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" />
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* MOBILE VERSION - STACKED CARDS */}
    <div class="sm:hidden space-y-4">
      {items.map((item: any) => (
        <div class="bg-white border-2 border-slate-200 rounded-2xl p-5">
          <h4 class="font-black text-base text-slate-800 mb-3 flex items-center gap-2">
            {item.icon && <span class="text-xl">{item.icon}</span>}
            {item.title}
          </h4>
          <ul class="space-y-2">
            {item.points && item.points.map((point: string) => (
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <Icon name="bx:check-circle" class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" />
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
)}

{/* STEPS - КРОКОВА ІНСТРУКЦІЯ */}
{type === 'steps' && (
  <div class="my-6 space-y-4 not-prose">
    {items.map((item: any, idx: number) => (
      <div class="flex gap-4 group">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-600 to-purple-600 flex items-center justify-center text-white font-black text-lg shadow-lg group-hover:scale-110 group-hover:rotate-6 transition-all">
            {idx + 1}
          </div>
          {idx < items.length - 1 && (
            <div class="w-0.5 h-8 bg-gradient-to-b from-blue-600 to-purple-600 ml-6 mt-2 opacity-30"></div>
          )}
        </div>
        <div class="flex-1 pb-4">
          <h4 class="font-black text-base sm:text-lg text-slate-800 mb-2">{item.title}</h4>
          <p class="text-sm sm:text-base text-slate-600 leading-relaxed">{item.text}</p>
        </div>
      </div>
    ))}
  </div>
)}

{/* INFO BOXES - ІНФОРМАЦІЙНІ КАРТКИ */}
{type === 'info-boxes' && (
  <div class="grid gap-3 my-6 not-prose">
    {items.map((item: any, idx: number) => (
      <div class="flex gap-3 p-4 bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-200 rounded-xl hover:shadow-lg transition-all group" style={`animation-delay: ${idx * 100}ms`}>
        {item.icon && (
          <div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-blue-600 flex items-center justify-center text-xl sm:text-2xl shadow-md group-hover:scale-110 group-hover:rotate-12 transition-all">
            <span class="grayscale brightness-[3]">{item.icon}</span>
          </div>
        )}
        <div class="flex-1 min-w-0">
          <h4 class="font-black text-sm sm:text-base text-slate-800 mb-1">{item.title}</h4>
          <p class="text-xs sm:text-sm text-slate-600 leading-relaxed">{item.text}</p>
        </div>
      </div>
    ))}
  </div>
)}

{/* TABS - ТАБУЛЯЦІЇ ДЛЯ МОБІЛЬНИХ (DROPDOWN) */}
{type === 'mobile-tabs' && (
  <div class="my-6 not-prose" x-data="{ activeTab: 0 }">
    {/* MOBILE - SELECT DROPDOWN */}
    <div class="sm:hidden mb-4">
      <select x-model="activeTab" class="w-full p-3 rounded-xl border-2 border-slate-200 font-bold text-slate-800 bg-white">
        {items.map((item: any, idx: number) => (
          <option value={idx}>{item.icon} {item.title}</option>
        ))}
      </select>
    </div>

    {/* DESKTOP - BUTTONS */}
    <div class="hidden sm:flex gap-2 mb-4 overflow-x-auto pb-2">
      {items.map((item: any, idx: number) => (
        <button
          x-on:click={`activeTab = ${idx}`}
          x-bind:class={`activeTab === ${idx} ? 'bg-gradient-to-br from-blue-600 to-blue-700 text-white shadow-xl' : 'bg-white text-slate-700 hover:bg-slate-50'`}
          class="px-4 py-2 rounded-xl font-bold text-sm border-2 border-slate-200 transition-all whitespace-nowrap flex items-center gap-2"
        >
          {item.icon && <span>{item.icon}</span>}
          {item.title}
        </button>
      ))}
    </div>

    {/* CONTENT */}
    {items.map((item: any, idx: number) => (
      <div x-show={`activeTab === ${idx}`} x-transition class="bg-white border-2 border-slate-200 rounded-2xl p-4 sm:p-6">
        <div class="prose prose-sm sm:prose max-w-none" set:html={item.content} />
      </div>
    ))}
  </div>
)}

{/* QUOTE BLOCK */}
{type === 'quote-block' && (
  <div class="my-6 relative p-5 sm:p-6 bg-gradient-to-br from-blue-50 to-indigo-50 border-l-4 border-blue-600 rounded-2xl not-prose group hover:shadow-lg transition-all">
    <div class="absolute top-3 left-3 text-5xl sm:text-6xl text-blue-600/10 font-black leading-none">"</div>
    <div class="relative pl-6 sm:pl-8">
      <p class="text-sm sm:text-base text-slate-700 italic leading-relaxed mb-3">
        <slot />
      </p>
      {text && (
        <cite class="text-xs sm:text-sm font-bold text-blue-600 not-italic">— {text}</cite>
      )}
    </div>
  </div>
)}

{/* EMOJI CARDS - КАРТКИ З ЕМОДЖІ */}
{type === 'emoji-cards' && (
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 my-6 not-prose">
    {items.map((item: any, idx: number) => (
      <div class="flex items-center gap-3 p-4 bg-white border-2 border-slate-200 rounded-xl hover:border-blue-300 hover:shadow-lg hover:-translate-y-1 transition-all group" style={`animation-delay: ${idx * 80}ms`}>
        <div class="flex-shrink-0 text-3xl sm:text-4xl group-hover:scale-125 group-hover:rotate-12 transition-all">
          {item.icon}
        </div>
        <div class="flex-1 min-w-0">
          <h4 class="font-black text-sm sm:text-base text-slate-800">{item.title}</h4>
        </div>
      </div>
    ))}
  </div>
)}

<script>
  // Alpine.js для табів
  if (typeof window !== 'undefined' && !window.Alpine) {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js';
    script.defer = true;
    document.head.appendChild(script);
  }
</script>

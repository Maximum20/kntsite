---
import { Icon } from "astro-icon/components";

// Дані для пошуку
const searchIndex = [
  { title: "Мегавольтна терапія (Лінійні прискорювачі)", tags: ["лінійник", "linac", "електа", "elekta", "versa", "опромінення", "пухлина"], url: "/services/linac", category: "відділення" },
  { title: "КТ-розмітка (Симуляція)", tags: ["кт", "комп'ютерна томографія", "симуляція", "планування"], url: "/services/ct", category: "послуга" },
  { title: "Брахітерапія", tags: ["контактна променева терапія", "джерело", "іридій"], url: "/services/brachy", category: "відділення" },
  { title: "Діденко Олександр Петрович", tags: ["лікар", "радіолог", "онколог", "завідувач"], url: "/doctors", category: "лікар" },
  { title: "Контакти та графік роботи", tags: ["телефон", "адреса", "як доїхати", "головний лікар"], url: "#contacts", category: "інфо" }
];
---

{/* --- 1. КНОПКИ В ШАПЦІ (ТВОЄ МЕНЮ) --- */}
<div class="hidden xl:flex items-center gap-2 mr-6 ml-4 bg-slate-50/50 p-1 rounded-full border border-slate-100">
  <div class="flex items-center gap-2.5 px-3">
    <a href="#" class="text-slate-400 hover:text-[#1877F2] transition-all hover:scale-110"><Icon name="bx:bxl-facebook-circle" class="w-5 h-5" /></a>
    <a href="#" class="text-slate-400 hover:text-[#0088cc] transition-all hover:scale-110"><Icon name="bx:bxl-telegram" class="w-5 h-5" /></a>
    <a href="#" class="text-slate-400 hover:text-[#E4405F] transition-all hover:scale-110"><Icon name="bx:bxl-instagram" class="w-5 h-5" /></a>
    <a href="#" class="text-slate-400 hover:text-[#FF0000] transition-all hover:scale-110"><Icon name="bx:bxl-youtube" class="w-5 h-5" /></a>
  </div>
  <div class="w-px h-4 bg-slate-200 mx-1"></div>
  <button id="search-trigger" class="relative flex items-center justify-center w-9 h-9 rounded-full bg-white shadow-sm text-blue-600 hover:bg-blue-600 hover:text-white transition-all group">
    <Icon name="bx:bx-search" class="w-4 h-4" />
    <span class="absolute -top-0.5 -right-0.5 w-2 h-2 bg-blue-500 rounded-full border-2 border-white animate-pulse"></span>
  </button>
</div>

{/* --- 2. ВІКНО ПОШУКУ (MODAL) --- */}
<div id="search-modal" class="fixed inset-0 z-[999] hidden bg-slate-900/40 backdrop-blur-2xl items-start justify-center pt-20 px-4 font-sans">
  <div class="bg-white/90 backdrop-blur-3xl w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden border border-white/60 animate-in zoom-in-95 duration-300 flex flex-col max-h-[85vh]">
    
    {/* TABS З ПЛАВАЮЧОЮ ЛІНІЄЮ */}
    <div class="relative flex border-b border-slate-100 bg-slate-50/50 flex-shrink-0">
      <button id="tab-offline" class="flex-1 py-5 text-[10px] font-black uppercase tracking-widest transition-colors duration-300 z-10 text-blue-600">Офлайн пошук</button>
      <button id="tab-ai" class="flex-1 py-5 text-[10px] font-black uppercase tracking-widest transition-colors duration-300 z-10 text-slate-400 hover:text-blue-600">AI Помічник (Gemini)</button>
      
      {/* ПЛАВАЮЧИЙ ПІДКРЕСЛЮВАЧ */}
      <div id="tab-indicator" class="absolute bottom-0 left-0 h-0.5 bg-blue-600 transition-all duration-300 ease-out" style="width: 50%; transform: translateX(0);"></div>
    </div>

    <div class="p-8 flex flex-col flex-1 overflow-hidden">
      {/* Search Input */}
      <div class="flex items-center gap-4 bg-white/50 px-6 py-5 rounded-2xl border border-slate-200 focus-within:ring-2 ring-blue-500/20 transition-all shadow-inner flex-shrink-0">
        <Icon name="bx:bx-search" class="w-6 h-6 text-blue-500" />
        <input id="search-input" type="text" placeholder="Шукайте лікаря або відділення..." class="bg-transparent border-none outline-none w-full font-bold text-slate-700 placeholder:text-slate-400" autocomplete="off" />
        <div id="ai-loader" class="hidden">
           <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
      </div>
      
      {/* OFFLINE SECTION */}
      <div id="offline-content" class="mt-8 overflow-y-auto no-scrollbar transition-all duration-300 opacity-100 translate-x-0">
        <div id="suggestions-box">
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 mb-4 px-2 text-left">Вас може зацікавити:</p>
          <div class="flex flex-wrap gap-2">
            <button class="tag-btn px-5 py-2.5 rounded-full bg-white text-slate-600 text-xs font-bold border border-slate-100 hover:border-blue-400 hover:text-blue-600 transition-all shadow-sm active:scale-95" data-query="#лікар">Знайти лікаря</button>
            <button class="tag-btn px-5 py-2.5 rounded-full bg-white text-slate-600 text-xs font-bold border border-slate-100 hover:border-blue-400 hover:text-blue-600 transition-all shadow-sm active:scale-95" data-query="#відділення">Про відділення</button>
            <button class="tag-btn px-5 py-2.5 rounded-full bg-white text-slate-600 text-xs font-bold border border-slate-100 hover:border-blue-400 hover:text-blue-600 transition-all shadow-sm active:scale-95" data-query="лінійний прискорювач">Лінійні прискорювачі</button>
          </div>
        </div>

        <div id="results-list" class="mt-6 space-y-2 hidden">
          {/* Сюди JS підставлятиме результати */}
        </div>
      </div>

      {/* AI SECTION */}
      <div id="ai-content" class="mt-8 hidden flex flex-col flex-1 overflow-hidden transition-all duration-300 opacity-0 translate-x-10">
        <div id="chat-messages" class="flex-1 overflow-y-auto space-y-4 pr-2 mb-4 no-scrollbar min-h-[300px]">
          <div class="flex justify-start">
            <div class="bg-blue-600 text-white p-4 rounded-2xl rounded-tl-none text-sm max-w-[85%] shadow-md leading-relaxed">
              Вітаю! Я ваш інтелектуальний помічник. Запитуйте про обладнання, процедури або лікарів.
            </div>
          </div>
        </div>

        <button id="clear-chat" class="text-[10px] uppercase font-black text-slate-400 hover:text-red-500 transition-all mb-2 self-end px-2">
          Очистити історію
        </button>
      </div>
    </div>
  </div>
  <div id="search-close" class="fixed inset-0 -z-10 cursor-pointer"></div>
</div>

<script define:vars={{ searchIndex }}>
  // 1. ТЕЛЕПОРТ
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('search-modal');
    if (modal) document.body.appendChild(modal);
  });

  const trigger = document.getElementById('search-trigger');
  const modal = document.getElementById('search-modal');
  const close = document.getElementById('search-close');
  const input = document.getElementById('search-input');
  
  const tOff = document.getElementById('tab-offline');
  const tAI = document.getElementById('tab-ai');
  const indicator = document.getElementById('tab-indicator');
  
  const cOff = document.getElementById('offline-content');
  const cAI = document.getElementById('ai-content');
  
  const resultsList = document.getElementById('results-list');
  const suggestionsBox = document.getElementById('suggestions-box');
  const chatMessages = document.getElementById('chat-messages');
  const clearChatBtn = document.getElementById('clear-chat');
  const aiLoader = document.getElementById('ai-loader');

  let currentTab = 'offline';
  let chatHistory = [];

  // --- Логіка плавного перемикання вкладок ---
  const switchToTab = (tab) => {
    currentTab = tab;
    
    if (tab === 'ai') {
      // Анімація лінії
      indicator.style.transform = 'translateX(100%)';
      
      // Стилі тексту
      tAI.classList.replace('text-slate-400', 'text-blue-600');
      tOff.classList.replace('text-blue-600', 'text-slate-400');
      
      // Контент
      cOff.classList.add('hidden');
      cAI.classList.remove('hidden');
      
      // Плавна поява контенту AI
      setTimeout(() => {
        cAI.style.opacity = '1';
        cAI.style.transform = 'translateX(0)';
      }, 10);
      
      input.placeholder = "Напишіть ваше запитання до AI...";
    } else {
      // Анімація лінії назад
      indicator.style.transform = 'translateX(0)';
      
      // Стилі тексту
      tOff.classList.replace('text-slate-400', 'text-blue-600');
      tAI.classList.replace('text-blue-600', 'text-slate-400');
      
      // Контент
      cAI.classList.add('hidden');
      cOff.classList.remove('hidden');
      cAI.style.opacity = '0';
      cAI.style.transform = 'translateX(10px)';
      
      input.placeholder = "Шукайте лікаря або відділення...";
    }
    input.focus();
  };

  tOff?.addEventListener('click', () => switchToTab('offline'));
  tAI?.addEventListener('click', () => switchToTab('ai'));

  // --- Відкриття/закриття ---
  trigger?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    input?.focus();
    document.body.style.overflow = 'hidden';
  });

  const hideModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = 'auto';
  };
  close?.addEventListener('click', hideModal);

  // --- Пошук (Твоя логіка) ---
  function performSearch(query) {
    const rawQ = query.toLowerCase().trim();
    if (rawQ.length < 2) {
      resultsList?.classList.add('hidden');
      suggestionsBox?.classList.remove('hidden');
      return;
    }
    suggestionsBox?.classList.add('hidden');
    resultsList?.classList.remove('hidden');
    const filtered = searchIndex.filter(item => 
      item.title.toLowerCase().includes(rawQ) || item.tags.some(t => t.includes(rawQ))
    );
    renderResults(filtered);
  }

  function renderResults(results) {
    if (!resultsList) return;
    resultsList.innerHTML = results.length === 0 
      ? `<p class="text-xs text-slate-400 p-4 text-center">Нічого не знайдено</p>`
      : results.map(item => `
          <a href="${item.url}" class="group block p-4 rounded-2xl bg-white border border-slate-100 hover:border-blue-400 hover:bg-blue-50/30 transition-all shadow-sm">
            <div class="flex items-center justify-between">
              <div class="flex flex-col text-left">
                <span class="text-[10px] font-black uppercase text-blue-500 mb-1">${item.category}</span>
                <span class="font-bold text-slate-700">${item.title}</span>
              </div>
              <div class="text-slate-300 group-hover:text-blue-600 transition-all">➔</div>
            </div>
          </a>
        `).join('');
  }

  // --- Чат з AI ---
  function appendBubble(role, content) {
    const isAi = role === 'assistant';
    const div = document.createElement('div');
    div.className = `flex ${isAi ? 'justify-start' : 'justify-end'} animate-in fade-in slide-in-from-bottom-1 duration-300`;
    div.innerHTML = `
      <div class="${isAi ? 'bg-blue-600 text-white rounded-tl-none' : 'bg-slate-100 text-slate-700 rounded-tr-none'} p-4 rounded-2xl text-sm max-w-[85%] shadow-sm leading-relaxed whitespace-pre-wrap text-left">
        ${content}
      </div>
    `;
    chatMessages.appendChild(div);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return div.querySelector('div');
  }

  async function handleAiSearch() {
    const question = input.value.trim();
    if (!question) return;

    appendBubble('user', question);
    chatHistory.push({ role: 'user', content: question });
    
    input.value = "";
    input.disabled = true;
    aiLoader?.classList.remove('hidden');

    const aiBubble = appendBubble('assistant', "...");
    aiBubble.innerText = "";

    try {
      const response = await fetch('/api/chats', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: chatHistory }),
      });

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let fullResponse = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        fullResponse += decoder.decode(value, { stream: true });
        aiBubble.innerText = fullResponse;
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      chatHistory.push({ role: 'assistant', content: fullResponse });
    } catch (err) {
      aiBubble.innerText = "Помилка зв'язку.";
    } finally {
      aiLoader?.classList.add('hidden');
      input.disabled = false;
      input.focus();
    }
  }

  // Обробка подій
  input?.addEventListener('input', (e) => {
    if (currentTab === 'offline') performSearch(e.target.value);
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && currentTab === 'ai') {
      e.preventDefault();
      handleAiSearch();
    }
  });

  clearChatBtn?.addEventListener('click', () => {
    chatHistory = [];
    chatMessages.innerHTML = `<div class="flex justify-start"><div class="bg-blue-600 text-white p-4 rounded-2xl rounded-tl-none text-sm max-w-[85%] shadow-md leading-relaxed">Історію очищено.</div></div>`;
  });

  document.querySelectorAll('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.getAttribute('data-query');
      input.value = q;
      if (currentTab === 'offline') performSearch(q);
      input.focus();
    });
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  #chat-messages { scroll-behavior: smooth; }
</style>
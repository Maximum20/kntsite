---
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import fullLogo from "../../assets/full-logo.png";

const menuitems = [
  { title: "Про відділення", path: "/about" },
  { title: "Послуги", path: "/services" },
  { title: "Лікарі", path: "/doctors" },
  { title: "Контакти", path: "/contact" },
];

const mainClinic = { title: "На головну клініки", path: "https://dokod.org.ua/" };
---

<!-- Липка шапка працює тепер з xl, щоб уникнути колізії -->
<header class="w-full xl:sticky xl:top-0 z-50 transition-all duration-300 xl:bg-white/90 xl:backdrop-blur-md xl:border-b xl:border-slate-100 xl:shadow-sm">
  <div class="max-w-screen-2xl mx-auto px-5 font-sans">
    <div class="flex flex-col xl:flex-row items-center py-4 xl:py-3 gap-4">
      <Astronav>
        <div class="flex w-full xl:w-auto items-center justify-between">
          
          <!-- ЛОГО + ТЕКСТ КНТ "ДОКОД" ДОР -->
          <div class="flex items-center gap-2 sm:gap-4">
            <a href="/" class="flex items-center shrink-0 transition-transform hover:scale-105">
              <Image 
                src={fullLogo} 
                alt="Логотип КНТ Дніпро" 
                class="h-10 md:h-12 xl:h-16 w-auto object-contain" 
                loading="eager"
                format="webp"
              />
            </a>
            <div class="flex items-center border-l border-slate-200 pl-2 sm:pl-4">
              <span class="text-slate-500 font-bold text-[9px] sm:text-[12px] xl:text-[13px] uppercase leading-tight">
                КНТ "ДОКОД" ДОР
              </span>
            </div>
          </div>
          
          <!-- Бургер тепер з'являється раніше (на xl) -->
          <div class="flex items-center gap-3 xl:hidden">
             <a href="#contacts" class="text-blue-600 bg-blue-50 border border-blue-100 rounded-full px-4 py-2 flex items-center gap-2 font-bold text-xs shadow-sm active:scale-95">
              <Icon name="bx:bxs-phone-call" class="w-4 h-4" />
              Зв'язок
            </a>
            <MenuIcon class="w-8 h-8 text-slate-800" />
          </div>
        </div>
        
        <!-- Меню розгортається тепер тільки на дуже широких екранах (xl) -->
        <MenuItems class="hidden w-full xl:w-auto mt-4 xl:flex xl:mt-0 xl:ml-auto">
          <ul class="flex flex-col xl:flex-row xl:gap-1 2xl:gap-4 items-start xl:items-center w-full xl:w-auto">
            
            {menuitems.map((item) => (
              <li class="w-full xl:w-auto">
                <a 
                  href={item.path} 
                  class="flex items-center gap-2 px-3 2xl:px-4 py-3 xl:py-2.5 rounded-full text-[15px] xl:text-[13px] 2xl:text-[14px] font-bold text-slate-600 transition-all duration-300 hover:bg-blue-50 hover:text-blue-600 xl:hover:-translate-y-0.5 group w-full"
                >
                  <div class="w-2 h-2 rounded-full bg-blue-200 group-hover:bg-blue-500 transition-colors shadow-[0_0_8px_rgba(59,130,246,0.3)] shrink-0 group-hover:scale-110"></div>
                  <span class="whitespace-nowrap">{item.title}</span>
                </a>
              </li>
            ))}

            <div class="hidden xl:block w-px h-6 bg-slate-200 mx-1 2xl:mx-2"></div>

            <!-- Кнопка Клініки -->
            <li class="mt-6 xl:mt-0 w-full xl:w-auto px-4 xl:px-0">
              <a 
                href={mainClinic.path} 
                target="_blank" 
                class="flex items-center justify-center xl:justify-start gap-2 px-4 2xl:px-6 py-3 xl:py-2 rounded-xl xl:rounded-full bg-slate-50 text-slate-700 font-bold text-[13px] hover:bg-slate-800 hover:text-white xl:hover:-translate-y-0.5 transition-all shadow-sm border border-slate-200 group w-full xl:w-auto"
              >
                <Icon name="bx:link-external" class="w-4 h-4 opacity-50 group-hover:opacity-100" />
                <span class="whitespace-nowrap">{mainClinic.title}</span>
              </a>
            </li>

            <!-- Кнопка Зв'язок -->
            <li class="mt-3 xl:mt-0 w-full xl:w-auto px-4 xl:px-0">
              <a 
                href="#contacts" 
                class="flex items-center justify-center gap-2 bg-blue-600 text-white px-6 2xl:px-8 py-3.5 xl:py-2.5 rounded-xl xl:rounded-full font-bold transition-all hover:bg-blue-700 hover:scale-[1.02] xl:hover:scale-105 xl:hover:shadow-blue-200 shadow-lg shadow-blue-100 text-[15px] xl:text-[13px] 2xl:text-[14px] active:scale-95 border-2 border-transparent w-full xl:w-auto"
              >
                <Icon name="bx:bxs-phone-call" class="w-5 h-5 xl:w-4 h-4" />
                <span class="whitespace-nowrap">Зв'язок</span>
              </a>
            </li>

          </ul>
        </MenuItems>
      </Astronav>
    </div>
  </div>
</header>
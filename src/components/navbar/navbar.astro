---
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Image } from "astro:assets";
import fullLogo from "../../assets/full-logo.jpg";

const menuitems = [
  { title: "Про відділення", path: "/about" },
  { title: "Послуги", path: "/services" },
  { title: "Лікарі", path: "/doctors" },
  { title: "Контакти", path: "/contact" },
  { title: "На головну клініки", path: "https://dokod.org.ua/", external: true },
];

const socials = [
  { name: "Facebook", url: "https://www.facebook.com/kz.kod.dor", icon: "fb", color: "hover:text-blue-600" },
  { name: "Instagram", url: "https://www.instagram.com/dokod.dp/", icon: "ig", color: "hover:text-pink-600" },
  { name: "Telegram", url: "https://t.me/dokod_dp", icon: "tg", color: "hover:text-sky-500" },
  { name: "YouTube", url: "https://youtube.com/@dokodlic", icon: "yt", color: "hover:text-red-600" },
  { name: "TikTok", url: "https://www.tiktok.com/@dokod_dp", icon: "tt", color: "hover:text-black" },
];
---

<!-- ПАНЕЛЬ КОНТАКТІВ (Виїжджає при натисканні) -->
<div id="contact-panel" class="hidden bg-slate-50 border-b border-slate-200 overflow-hidden">
  <div class="max-w-screen-2xl mx-auto px-5 py-8 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      
      <!-- Телефони -->
      <div class="flex flex-col gap-4">
        <h3 class="text-blue-600 font-bold uppercase text-xs tracking-widest opacity-80">Телефони реєстратури</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-slate-800 font-bold text-lg md:text-xl tracking-tight">
          <a href="tel:+380567207901" class="hover:text-blue-600 transition">(056) 720-79-01</a>
          <a href="tel:+380662904491" class="hover:text-blue-600 transition">(066) 290-44-91</a>
          <a href="tel:+380939585567" class="hover:text-blue-600 transition">(093) 958-55-67</a>
          <a href="tel:+380680015515" class="hover:text-blue-600 transition">(068) 001-55-15</a>
        </div>
      </div>

      <!-- Пошта -->
      <div class="flex flex-col gap-4 md:border-x md:border-slate-200 md:px-10">
        <h3 class="text-blue-600 font-bold uppercase text-xs tracking-widest opacity-80">Електронна пошта</h3>
        <a href="mailto:kz-kod-dor@ukr.net" class="text-xl md:text-2xl font-bold text-slate-800 hover:text-blue-600 break-all tracking-tighter">
          kz-kod-dor@ukr.net
        </a>
        <p class="text-slate-500 text-sm font-medium">м. Дніпро, вул. Космічна, 21</p>
      </div>

      <!-- Соцмережі -->
      <div class="flex flex-col gap-4">
        <h3 class="text-blue-600 font-bold uppercase text-xs tracking-widest opacity-80 text-center md:text-left">Ми у соцмережах</h3>
        <div class="flex flex-wrap gap-6 justify-center md:justify-start">
          {socials.map((soc) => (
            <a href={soc.url} target="_blank" rel="noopener" class={`text-slate-400 transition-all duration-300 transform hover:scale-125 ${soc.color}`} title={soc.name}>
               {soc.icon === 'fb' && <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>}
               {soc.icon === 'ig' && <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>}
               {soc.icon === 'tg' && <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M20.665 3.717l-17.73 6.837c-1.213.486-1.203 1.163-.223 1.467l4.55 1.42 10.532-6.645c.498-.303.953-.14.578.192l-8.533 7.707-.33 4.955c.483 0 .697-.223.967-.483l2.325-2.26 4.837 3.57c.89.49 1.53.24 1.752-.823l3.17-14.937c.325-1.3-.5-1.894-1.352-1.51z"/></svg>}
               {soc.icon === 'yt' && <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>}
               {soc.icon === 'tt' && <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 448 512"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/></svg>}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-screen-2xl mx-auto px-5 font-sans">
  <header class="flex flex-col lg:flex-row items-center py-6 gap-4">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center shrink-0">
          <Image 
            src={fullLogo} 
            alt="Логотип КНТ Дніпро" 
            class="h-12 md:h-14 lg:h-18 w-auto object-contain" 
            loading="eager"
            format="webp"
          />
        </a>
        
        <div class="flex items-center gap-3 lg:hidden">
          <button class="toggle-contacts-btn text-blue-600 bg-blue-50 border border-blue-100 rounded-full px-4 py-2 flex items-center gap-2 font-bold text-xs transition-all active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Зв'язок
          </button>
          <MenuIcon class="w-8 h-8 text-slate-800" />
        </div>
      </div>
      
      <MenuItems class="hidden w-full lg:w-auto mt-4 lg:flex lg:mt-0 lg:ml-auto">
        <ul class="flex flex-col lg:flex-row lg:gap-5 xl:gap-8 items-center">
          {menuitems.map((item) => (
            <li>
              <a
                href={item.path}
                target={item.external ? "_blank" : "_self"}
                rel={item.external ? "noopener" : ""}
                class:list={[
                  "flex lg:px-2 py-2 items-center font-bold transition text-[15px] tracking-tight group",
                  item.external 
                    ? "text-blue-600 hover:text-blue-800 italic" 
                    : "text-slate-600 hover:text-blue-600"
                ]}>
                <span>{item.title}</span>
                {item.external && (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5 ml-1.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
                  </svg>
                )}
              </a>
            </li>
          ))}
          
          <li class="hidden lg:block ml-2">
            <button class="toggle-contacts-btn flex items-center gap-2 font-bold text-blue-600 hover:bg-blue-50 px-4 py-2 rounded-full transition-all text-[15px]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Зв'язок
            </button>
          </li>
        </ul>
      </MenuItems>
    </Astronav>
  </header>
</div>

<script>
  const buttons = document.querySelectorAll('.toggle-contacts-btn');
  const panel = document.getElementById('contact-panel');

  if (panel && buttons.length > 0) {
    buttons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        panel.classList.toggle('hidden');
        if (!panel.classList.contains('hidden')) {
           window.scrollTo({ top: 0, behavior: 'smooth' });
           panel.animate([
             { transform: 'translateY(-20px)', opacity: 0 },
             { transform: 'translateY(0)', opacity: 1 }
           ], { duration: 300, easing: 'ease-out' });
        }
      });
    });
  }
</script>
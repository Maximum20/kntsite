---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero.astro";
import News from "../components/news.astro";
import { Icon } from "astro-icon/components"; // Переконайся, що цей імпорт є, якщо використовуєш Icon
---

<Layout title="Відділення променевої терапії">
  <main class="grid gap-20 mt-16 text-slate-800">
    <Hero />
    
    <section class="container mx-auto px-5">
      <div class="mt-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-center tracking-tight">Сучасні технології лікування</h2>
        <p class="text-lg mt-4 text-slate-600 text-center max-w-xl mx-auto font-medium">
          Використовуємо передове обладнання Elekta для досягнення найкращих результатів у боротьбі з хворобою.
        </p>
      </div>
      
      <div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16 text-center">
        <div>
           <div class="rounded-full bg-blue-100 p-4 w-16 h-16 mx-auto flex items-center justify-center text-blue-600 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight">Висока точність</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">Субміліметровий контроль дози опромінення.</p>
        </div>
        <div>
           <div class="rounded-full bg-green-100 p-4 w-16 h-16 mx-auto flex items-center justify-center text-green-600 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight">Швидкість VMAT</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">Сеанс триває 2-5 хвилин, що комфортно для пацієнта.</p>
        </div>
        <div>
           <div class="rounded-full bg-purple-100 p-4 w-16 h-16 mx-auto flex items-center justify-center text-purple-600 shadow-sm">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12H15M12 9V15M12 2L2 7L12 22L22 7L12 2Z" /></svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight">Безпека</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">Максимальний захист здорових тканин та органів.</p>
        </div>
      </div>
    </section>

    <section class="bg-slate-50 py-16 px-5 border-y border-slate-200">
      <div class="container mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 tracking-tight text-slate-900">Як проходить лікування?</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-40">01</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight text-blue-900">Консультація</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Огляд провідним лікарем та детальний аналіз КТ/МРТ знімків.</p>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-40">02</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight text-blue-900">КТ-розмітка</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Виготовлення фіксуючих засобів та топометрична підготовка.</p>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-blue-100 shadow-blue-900/5 hover:shadow-md transition-shadow ring-1 ring-blue-50">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-40">03</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight text-blue-900">Контуринг</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Визначення лікарем точних меж пухлини та критичних органів для захисту здорових тканин.</p>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-40">04</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight text-blue-900">Планування</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Робота медичних фізиків над створенням оптимального 3D-плану лікування.</p>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
            <div class="text-blue-600 font-black text-4xl mb-6 opacity-40">05</div>
            <h4 class="font-bold text-lg mb-3 tracking-tight text-blue-900">Опромінення</h4>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">Курс сеансів на лінійному прискорювачі Elekta Versa HD.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="contacts" class="container mx-auto px-5 pt-6 pb-10 scroll-mt-4">
      <div class="bg-slate-900 rounded-[2rem] p-8 md:p-16 text-white shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 rounded-full blur-[120px] opacity-20 -mr-32 -mt-32"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold mb-8 md:mb-12 tracking-tighter">Наші контакти</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
            <div class="flex flex-col gap-4 md:gap-6">
              <span class="text-blue-400 font-bold uppercase text-[10px] md:text-xs tracking-widest">Реєстратура</span>
              <div class="flex flex-col gap-2 md:gap-4 text-lg md:text-2xl font-bold tracking-tight">
                <a href="tel:+380567207901" class="hover:text-blue-400 transition-colors">(056) 720-79-01</a>
                <a href="tel:+380662904491" class="hover:text-blue-400 transition-colors">(066) 290-44-91</a>
                <a href="tel:+380939585567" class="hover:text-blue-400 transition-colors">(093) 958-55-67</a>
                <a href="tel:+380680015515" class="hover:text-blue-400 transition-colors">(068) 001-55-15</a>
              </div>
            </div>

            <div class="flex flex-col gap-4 md:gap-6 md:border-x md:border-slate-800 md:px-10">
              <span class="text-blue-400 font-bold uppercase text-[10px] md:text-xs tracking-widest">Адреса та пошта</span>
              <div class="space-y-2 md:space-y-4">
                <a href="mailto:linac_olt1@ukr.net" class="text-base md:text-xl font-bold hover:text-blue-400 transition-colors block break-all tracking-tight">
                  linac_olt1@ukr.net
                </a>
                
                <a 
                  href="https://www.google.com/maps/search/?api=1&query=м.+Дніпро,+вул.+Космічна,+21+КНП+ДОКОД+ДОР" 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="group block"
                >
                  <p class="text-slate-400 text-sm md:text-base leading-snug font-medium group-hover:text-blue-400 transition-colors">
                    м. Дніпро, вул. Космічна, 21<br/>
                    КНТ "ДОКОД" ДОР
                  </p>
                  <span class="inline-flex items-center gap-1 text-[10px] text-blue-500 font-bold uppercase mt-1 opacity-0 group-hover:opacity-100 transition-all transform translate-y-1 group-hover:translate-y-0">
                    <Icon name="bx:map" class="w-3 h-3" /> Дивитись на карті
                  </span>
                </a>
              </div>
            </div>

            <div class="flex flex-col gap-4 md:gap-6">
              <span class="text-blue-400 font-bold uppercase text-[10px] md:text-xs tracking-widest">Ми в мережі</span>
              <div class="flex flex-wrap gap-3 md:gap-4">
                <a href="https://www.facebook.com/kz.kod.dor" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-blue-600 transition-all shadow-lg text-white">
                  <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
                </a>
                <a href="https://www.instagram.com/dokod.dp/" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-pink-600 transition-all shadow-lg text-white">
                  <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
                <a href="https://t.me/dokod_dp" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-sky-500 transition-all shadow-lg text-white">
                  <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.665 3.717l-17.73 6.837c-1.213.486-1.203 1.163-.223 1.467l4.55 1.42 10.532-6.645c.498-.303.953-.14.578.192l-8.533 7.707-.33 4.955c.483 0 .697-.223.967-.483l2.325-2.26 4.837 3.57c.89.49 1.53.24 1.752-.823l3.17-14.937c.325-1.3-.5-1.894-1.352-1.51z"/></svg>
                </a>
                <a href="https://www.youtube.com/@DOKOD_DP" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-red-600 transition-all shadow-lg text-white">
                  <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                </a>
                <a href="https://www.tiktok.com/@dokod.dp" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-800 flex items-center justify-center hover:bg-black transition-all shadow-lg text-white">
                  <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.9-.32-1.98-.23-2.84.2a2.921 2.921 0 0 0-1.5 2.75c-.02.73.23 1.48.73 2.01.62.65 1.53.97 2.41.91 1.25-.1 2.37-.96 2.75-2.15.11-.32.16-.65.16-.99.02-3.8.01-7.62.02-11.43z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <News />
    
  </main>
</Layout>
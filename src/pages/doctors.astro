---

<Layout title="Наші фахівці" hideSubNav={true}>
  <main class="relative min-h-screen w-full flex flex-col bg-transparent overflow-x-hidden pt-8 pb-20">

    <!-- Animated Particles - Desktop Only -->
    <div class="hidden md:block fixed inset-0 pointer-events-none overflow-hidden" id="particlesCanvas">
      <canvas id="particles" class="w-full h-full opacity-40"></canvas>
    </div>

    <!-- Decorative Floating Shapes - Desktop Only -->
    <div class="hidden lg:block fixed inset-0 pointer-events-none overflow-hidden opacity-20">
      <div class="floating-shape shape-1"></div>
      <div class="floating-shape shape-2"></div>
    </div>

    <!-- Header Navigation -->
    <div class="relative z-20 px-6 md:px-12 flex justify-between items-center mb-8">
      <a href="/" class="inline-flex items-center gap-3 text-slate-600 hover:text-slate-800 transition-all duration-300 group">
        <div class="w-11 h-11 rounded-2xl backdrop-blur-xl bg-white/60 border border-white/80 flex items-center justify-center group-hover:bg-white/80 transition-all duration-300 shadow-lg shadow-slate-200/50">
          <Icon name="bx:left-arrow-alt" class="w-6 h-6 group-hover:-translate-x-1 transition-transform duration-300 text-slate-700" />
        </div>
        <span class="hidden sm:block text-[9px] font-semibold uppercase tracking-[0.2em] text-slate-600">На головну</span>
      </a>

      <!-- Mobile Search Button -->
      <button id="toggleFilters" class="md:hidden w-12 h-12 rounded-2xl backdrop-blur-xl bg-slate-800/90 border border-white/20 text-white flex items-center justify-center shadow-xl active:scale-95 transition-all duration-200">
        <Icon name="bx:search" class="w-6 h-6" />
      </button>
    </div>

    <!-- Title Section -->
    <div class="text-center mb-10 px-4 relative z-10">
      <h1 class="text-[clamp(2.5rem,5vw,5rem)] font-serif font-bold tracking-tight leading-tight mb-2 gradient-text">
        Наша велика команда
      </h1>
      <p class="text-slate-500 font-medium uppercase tracking-[0.3em] text-[9px] opacity-70">
        Відділення променевої терапії
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-transparent via-slate-300 to-transparent mx-auto mt-4 rounded-full"></div>
    </div>

    <!-- Collapsible Filter Section -->
    <div id="filterPanel" class="hidden md:block relative z-30 max-w-6xl mx-auto w-full px-6 mb-10">
      <div class="backdrop-blur-2xl bg-white/70 border border-white/80 rounded-3xl shadow-2xl shadow-slate-200/30 overflow-hidden transition-shadow duration-300">

        <!-- Search Bar -->
        <div class="p-6 pb-4">
          <div class="relative group">
            <input
              type="text"
              id="nameSearch"
              placeholder="Пошук фахівця по імені або прізвищу..."
              class="w-full px-5 py-3.5 backdrop-blur-xl bg-white/80 border border-slate-200/60 rounded-2xl text-sm font-medium text-slate-800 placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-slate-200/50 transition-all shadow-sm"
            />
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none transition-transform">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8" stroke-width="2"/>
                <path d="M21 21l-4.35-4.35" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Advanced Filters Toggle -->
        <div class="px-6 pb-5">
          <button id="toggleAdvanced" class="w-full flex items-center justify-center gap-2 text-slate-600 hover:text-slate-800 font-semibold text-sm transition-all duration-300 group">
            <span>Розширені фільтри</span>
            <svg class="w-4 h-4 transition-transform duration-300 group-[.open]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>

        <!-- Advanced Filters -->
        <div id="advancedFilters" class="hidden overflow-hidden transition-all duration-300">
          <div class="px-6 pb-6 pt-2 border-t border-slate-200/50">

            <!-- Department Chips -->
            <div class="mb-5">
              <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-3">Відділення</label>
              <div class="flex flex-wrap gap-2" id="deptChips">
                <button class="filter-chip active" data-dept="">Всі</button>
                {departments.map(dept => (
                  <button class="filter-chip" data-dept={dept}>{dept}</button>
                ))}
              </div>
            </div>

            <!-- Role Chips -->
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-3">Посада</label>
              <div class="flex flex-wrap gap-2" id="roleChips">
                <button class="filter-chip active" data-role="">Всі</button>
                {roles.map(role => (
                  <button class="filter-chip" data-role={role}>{role}</button>
                ))}
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>

    <!-- Swiper Container -->
    <div class="flex-1 flex items-center justify-center relative z-10 w-full px-4 md:px-12 lg:px-20 xl:px-28 py-4">
      <div class="relative w-full max-w-[1900px]">

        <div class="swiper main-swiper w-full overflow-visible">
          <div class="swiper-wrapper" id="doctorsWrapper">
            <!-- Cards rendered by JS -->
          </div>

          <!-- No Results -->
          <div id="noResults" class="hidden text-center py-32">
            <div class="w-20 h-20 mx-auto mb-5 rounded-full backdrop-blur-xl bg-white/60 border border-white/80 flex items-center justify-center shadow-lg">
              <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" stroke-width="2"/>
                <path d="M12 8v4M12 16h.01" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <p class="text-slate-400 font-semibold uppercase tracking-wider text-xs">Спеціалістів не знайдено</p>
          </div>
        </div>

        <!-- Glass Navigation Buttons -->
        <button class="swiper-button-prev glass-nav hidden lg:flex" aria-label="Previous"></button>
        <button class="swiper-button-next glass-nav hidden lg:flex" aria-label="Next"></button>
      </div>
    </div>

    <!-- Floating Stats Badge - Desktop Only -->
    <div class="hidden lg:block fixed bottom-6 right-6 z-20 backdrop-blur-xl bg-white/60 border border-white/80 rounded-2xl px-4 py-3 shadow-xl opacity-0 hover:opacity-100 transition-opacity duration-300">
      <div class="text-[10px] font-bold uppercase tracking-wider text-slate-500 mb-1">Наша команда</div>
      <div class="text-2xl font-black text-slate-800" id="teamCount">7</div>
      <div class="text-[9px] text-slate-400 uppercase tracking-wide">фахівців</div>
    </div>


<div class="relative z-10 mt-10">
       <TeamGallery />
    </div>


  </main>
</Layout>

<style is:global>
  @import url('https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css');
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Crimson+Pro:wght@400;600;700&display=swap');

  html, body {
    overflow-y: auto !important;
    height: auto !important;
    min-height: 100vh;
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .font-serif {
    font-family: 'Crimson Pro', 'Georgia', serif;
  }

  /* Animated Gradient Text */
  .gradient-text {
    background: linear-gradient(
      90deg,
      #475569 0%,
      #1e293b 25%,
      #0f172a 50%,
      #1e293b 75%,
      #475569 100%
    );
    background-size: 200% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  @media (min-width: 768px) {
    .gradient-text {
      animation: gradient-shift 8s ease infinite;
    }
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Floating Shapes - Desktop Only */
  .floating-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
  }

  .shape-1 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
    top: 10%;
    left: 5%;
    animation: float-1 20s ease-in-out infinite;
  }

  .shape-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    top: 60%;
    right: 10%;
    animation: float-2 25s ease-in-out infinite;
  }

  @keyframes float-1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(50px, -30px); }
  }

  @keyframes float-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-60px, 40px); }
  }

  /* Modern Filter Chips */
  .filter-chip {
    padding: 0.65rem 1.2rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #475569;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .filter-chip:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: #cbd5e1;
    transform: translateY(-1px);
  }

  .filter-chip.active {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border-color: #1e293b;
    color: white;
    box-shadow: 0 4px 12px rgba(30, 41, 59, 0.3);
  }

  /* Optimized Card - Reduced blur on mobile */
 .liquid-card {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4.5;
  border-radius: 2rem;
  overflow: hidden;
  cursor: pointer;
  background: rgba(255, 255, 255, 0.9); /* Трохи щільніше для стабільності на мобільних */
  border: 1px solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s ease;
  -webkit-tap-highlight-color: transparent;
  
  /* Фікс для iOS: примусовий рендеринг шару */
  isolation: isolate; 
  -webkit-transform: translate3d(0, 0, 0);
  transform: translate3d(0, 0, 0);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  -webkit-perspective: 1000;
  perspective: 1000;
  
  touch-action: manipulation;
}

  /* Prevent flickering during transition */
  .liquid-card.is-expanded {
    isolation: isolate;
  }

  @media (min-width: 768px) {
    .liquid-card {
      backdrop-filter: blur(20px);
      box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.08),
        0 1px 3px rgba(0, 0, 0, 0.06),
        inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    }
  }

  .liquid-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 2rem;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(226, 232, 240, 0.4),
      rgba(203, 213, 225, 0.6),
      rgba(226, 232, 240, 0.4)
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  @media (hover: hover) {
    .liquid-card:hover::after {
      opacity: 1;
    }

    .liquid-card:hover {
  transform: translateY(-8px); /* Прибрали scale */
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.9);
}

    .liquid-card:hover .card-portrait {
      transform: scale(1.05);
    }
  }

  @media (max-width: 768px) {
    .liquid-card {
      border-radius: 1.5rem;
      aspect-ratio: 10/16;
    }
  }

  /* Card Image Container */
  .card-img-wrap {
  position: absolute;
  inset: 0;
  z-index: 1;
  /* Додаємо ці два рядки */
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
}

  .card-portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  /* Dark Gradient Overlay */
  .glass-overlay {
  position: absolute;
  inset: 0;
  /* Піднімаємо z-index вище картинки */
  z-index: 5; 
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.85) 0%,
    rgba(0, 0, 0, 0.4) 35%,
    transparent 75%
  );
  pointer-events: none;
  
  /* Мінімальний 3D-виліт, щоб не зникало на iOS */
  -webkit-transform: translate3d(0, 0, 1px);
  transform: translate3d(0, 0, 1px);
  
  /* Щоб уникнути мерехтіння */
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}



  /* Card Info */
  .card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 2rem 1.5rem 2rem;
    transition: opacity 0.25s ease, transform 0.25s ease;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  @media (max-width: 768px) {
    .card-info {
      padding: 1.5rem 1.3rem 1.8rem;
    }
  }

  /* Role Badge */
  .role-badge {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border-radius: 10px;
    font-size: 0.65rem;
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.9rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    position: relative;
  }

  @media (min-width: 768px) {
    .role-badge::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 11px;
      background: inherit;
      filter: blur(8px);
      opacity: 0.4;
      z-index: -1;
    }
  }

  /* Doctor Name */
  .doctor-name {
    font-family: 'Crimson Pro', serif;
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    letter-spacing: -0.02em;
    text-align: left;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4), 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  /* Tap Hint */
  .card-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.7rem;
    margin-top: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Details Panel - Optimized for smooth animation */
  .details-panel {
    position: absolute;
    inset: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.95);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    pointer-events: none;
    transform: translate3d(0, 100%, 0);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.2s ease;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    perspective: 1000px;
  }

  @media (min-width: 768px) {
    .details-panel {
      backdrop-filter: blur(40px);
      background: linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.88),
        rgba(255, 255, 255, 0.92)
      );
    }
  }

  .liquid-card.is-expanded .details-panel {
    pointer-events: auto;
    transform: translate3d(0, 0, 0);
    opacity: 1;
  }

  .liquid-card.is-expanded .card-info {
    opacity: 0;
    transform: translate3d(0, 10px, 0);
  }

  /* Details Inner */
  .details-inner {
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(248, 250, 252, 0.6),
      rgba(255, 255, 255, 0.8)
    );
    border-radius: 2rem 2rem 0 0;
    padding: 1.5rem 1.5rem 2rem;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  @media (min-width: 768px) {
    .details-inner {
      backdrop-filter: blur(20px);
    }
  }

  @media (max-width: 768px) {
    .details-inner {
      padding: 1.3rem 1.3rem 1.8rem;
      background: white;
    }
  }

  /* Drag Handle */
  .drag-handle {
    width: 40px;
    height: 4px;
    background: linear-gradient(to right, #cbd5e1, #94a3b8, #cbd5e1);
    border-radius: 10px;
    margin: 0 auto 1.2rem;
    opacity: 0.6;
  }

  /* Avatar */
  .detail-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2.5px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1), 0 0 0 3px rgba(148, 163, 184, 0.1);
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Labels */
  .detail-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #64748b;
    margin-bottom: 0.4rem;
  }

  .detail-value {
    color: #1e293b;
    font-weight: 600;
  }

  /* Bio */
  .bio-text {
    font-style: italic;
    font-weight: 500;
    color: #475569;
    border-left: 3px solid #94a3b8;
    padding-left: 1rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    background: linear-gradient(to right, rgba(241, 245, 249, 0.6), transparent);
    padding: 0.8rem 1rem;
    border-radius: 0 8px 8px 0;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
    margin-bottom: 1.5rem;
    padding: 1.2rem 0;
    border-top: 1px solid rgba(226, 232, 240, 0.6);
    border-bottom: 1px solid rgba(226, 232, 240, 0.6);
  }

  /* Specialization Tags */
  .spec-badge {
    padding: 0.5rem 0.9rem;
    background: linear-gradient(135deg, #475569 0%, #334155 100%);
    color: white;
    border-radius: 8px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  /* Book Button */
  .book-btn {
    width: 100%;
    padding: 1rem;
    border-radius: 14px;
    color: white;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: all 0.3s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .book-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .book-btn:active {
    transform: translateY(0);
  }

  /* Glass Navigation */
  .glass-nav {
    width: 50px !important;
    height: 50px !important;
    backdrop-filter: blur(20px) !important;
    background: rgba(255, 255, 255, 0.6) !important;
    border: 1px solid rgba(255, 255, 255, 0.8) !important;
    color: #475569 !important;
    border-radius: 50% !important;
    position: absolute !important;
    top: 50% !important;
    z-index: 50 !important;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06) !important;
    cursor: pointer;
    transform: translateY(-50%) !important;
    transition: all 0.3s ease !important;
  }

  .glass-nav:hover {
    background: rgba(255, 255, 255, 0.85) !important;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1) !important;
    transform: translateY(-50%) scale(1.1) !important;
  }

  .glass-nav::after {
    font-size: 1.3rem !important;
    font-weight: 700 !important;
  }

  .swiper-button-prev {
    left: -70px !important;
  }

  .swiper-button-next {
    right: -70px !important;
  }

  @media (min-width: 1280px) {
    .glass-nav {
      display: flex !important;
    }
  }

  /* Swiper Slide */
  .swiper-slide {
    padding: 25px 0;
    height: auto !important;
  }

  /* Custom Scrollbar */
  .details-inner::-webkit-scrollbar {
    width: 5px;
  }

  .details-inner::-webkit-scrollbar-track {
    background: rgba(241, 245, 249, 0.5);
  }

  .details-inner::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #cbd5e1, #94a3b8);
    border-radius: 10px;
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script is:inline define:vars={{ doctors }}>
  let mainSwiper;
  let activeFilters = {
    name: '',
    dept: '',
    role: ''
  };

  // Check if mobile
  const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 768;

  // Particles - Desktop Only
  function initParticles() {
    if (isMobile) return;

    const canvas = document.getElementById('particles');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const particles = [];
    const particleCount = 30;

    class Particle {
      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.size = Math.random() * 3 + 1;
        this.speedX = Math.random() * 0.5 - 0.25;
        this.speedY = Math.random() * 0.5 - 0.25;
        this.opacity = Math.random() * 0.5 + 0.2;
      }

      update() {
        this.x += this.speedX;
        this.y += this.speedY;

        if (this.x > canvas.width) this.x = 0;
        if (this.x < 0) this.x = canvas.width;
        if (this.y > canvas.height) this.y = 0;
        if (this.y < 0) this.y = canvas.height;
      }

      draw() {
        ctx.fillStyle = `rgba(148, 163, 184, ${this.opacity})`;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle());
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach(particle => {
        particle.update();
        particle.draw();
      });
      requestAnimationFrame(animate);
    }

    animate();

    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });
  }

  function initSwiper() {
    if (mainSwiper) {
      mainSwiper.destroy(true, true);
    }

    mainSwiper = new Swiper('.main-swiper', {
      slidesPerView: 1.15,
      centeredSlides: true,
      spaceBetween: 24,
      grabCursor: true,
      loop: false,
      speed: 400,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev'
      },
      breakpoints: {
        768: {
          slidesPerView: 2,
          spaceBetween: 28,
          centeredSlides: false
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 32,
          centeredSlides: false
        },
        1920: {
          slidesPerView: 3,
          spaceBetween: 36,
          centeredSlides: false
        },
        2560: {
          slidesPerView: 4,
          spaceBetween: 40,
          centeredSlides: false
        }
      }
    });
  }

  function renderDoctors(list) {
    const wrapper = document.getElementById('doctorsWrapper');
    const noResults = document.getElementById('noResults');
    const teamCount = document.getElementById('teamCount');

    if (teamCount) {
      teamCount.textContent = list.length;
    }

    if (!list || list.length === 0) {
      wrapper.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }

    noResults.classList.add('hidden');

    wrapper.innerHTML = list.map(doc => `
      <div class="swiper-slide">
        <div class="liquid-card" data-card>

          <div class="card-img-wrap">
            <img src="${doc.image}" alt="${doc.name} ${doc.surname}" class="card-portrait" loading="lazy" />
            <div class="glass-overlay"></div>
          </div>

          <div class="card-info">
            <div class="role-badge bg-gradient-to-r ${doc.color}">
              ${doc.role}
            </div>
            <h3 class="doctor-name text-[clamp(1.7rem,4vh,2.8rem)]">
              ${doc.name}<br/>${doc.surname}
            </h3>
            <div class="card-hint">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
              <span>Детальна анкета</span>
            </div>
          </div>

          <div class="details-panel">
            <div class="details-inner">

              <div class="drag-handle"></div>

              <div class="flex items-center gap-3 mb-5">
                <div class="detail-avatar">
                  <img src="${doc.image}" alt="${doc.name}" class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 text-base leading-tight">
                    ${doc.name} ${doc.surname}
                  </h4>
                  <span class="text-slate-600 font-semibold text-[10px] uppercase tracking-wide">
                    ${doc.role}
                  </span>
                </div>
              </div>

              <p class="bio-text text-sm">
                "${doc.bio}"
              </p>

              <div class="stats-grid">
                <div>
                  <span class="detail-label">Досвід</span>
                  <p class="detail-value text-xl font-bold">${doc.experience}</p>
                </div>
                <div>
                  <span class="detail-label">Освіта</span>
                  <p class="detail-value text-[10px] font-semibold uppercase leading-tight">
                    ${doc.education}
                  </p>
                </div>
              </div>

              <div class="mb-5">
                <span class="detail-label">Досягнення</span>
                <p class="detail-value text-sm">${doc.achievements}</p>
              </div>

              <div class="mb-6">
                <span class="detail-label mb-2 block">Ключові напрямки</span>
                <div class="flex flex-wrap gap-2">
                  ${doc.specializations.map(spec =>
                    `<span class="spec-badge">${spec}</span>`
                  ).join('')}
                </div>
              </div>

              

            </div>
          </div>

        </div>
      </div>
    `).join('');

    // Add click handlers with smooth animation
    document.querySelectorAll('[data-card]').forEach(card => {
      card.addEventListener('click', function(e) {
        if (e.target.closest('.book-btn')) return;

        // Close other cards first
        document.querySelectorAll('[data-card].is-expanded').forEach(otherCard => {
          if (otherCard !== this) {
            otherCard.classList.remove('is-expanded');
          }
        });

        // Use requestAnimationFrame for smooth animation
        requestAnimationFrame(() => {
          this.classList.toggle('is-expanded');
        });
      });
    });

    initSwiper();
  }

  function applyFilters() {
    const filtered = doctors.filter(doc => {
      const matchesName = !activeFilters.name ||
        doc.name.toLowerCase().includes(activeFilters.name) ||
        doc.surname.toLowerCase().includes(activeFilters.name);
      const matchesDept = !activeFilters.dept || doc.department === activeFilters.dept;
      const matchesRole = !activeFilters.role || doc.role === activeFilters.role;
      return matchesName && matchesDept && matchesRole;
    });

    renderDoctors(filtered);
  }

  let searchTimeout;
  function handleSearch(value) {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      activeFilters.name = value.trim().toLowerCase();
      applyFilters();
    }, 200);
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize desktop effects only
    if (!isMobile) {
      initParticles();
    }

    renderDoctors(doctors);



    // Встав це всередині DOMContentLoaded у doctors.astro
new Swiper('.team-swiper', {
  slidesPerView: 1,
  spaceBetween: 20,
  loop: true,
  speed: 800,
  autoHeight: true, // ВАЖЛИВО: слайдер сам виставить висоту по фото
  // Прибираємо ефект 'fade', краще залиш звичайне 'slide' для надійності пропорцій
  pagination: { el: '.team-pagination', clickable: true },
  navigation: { nextEl: '.team-next', prevEl: '.team-prev' },
  fadeEffect: {
    crossFade: true
  },
  pagination: {
    el: '.team-pagination',
    clickable: true,
  },
  navigation: {
    nextEl: '.team-next',
    prevEl: '.team-prev',
  },
  autoplay: {
    delay: 5000,
    disableOnInteraction: false,
  }
});



    const nameSearch = document.getElementById('nameSearch');
    if (nameSearch) {
      nameSearch.addEventListener('input', (e) => handleSearch(e.target.value));
    }

    const toggleAdvanced = document.getElementById('toggleAdvanced');
    const advancedFilters = document.getElementById('advancedFilters');

    if (toggleAdvanced && advancedFilters) {
      toggleAdvanced.addEventListener('click', () => {
        const isHidden = advancedFilters.classList.contains('hidden');

        if (isHidden) {
          advancedFilters.classList.remove('hidden');
          toggleAdvanced.classList.add('open');
        } else {
          advancedFilters.classList.add('hidden');
          toggleAdvanced.classList.remove('open');
        }
      });
    }

    const deptChips = document.querySelectorAll('#deptChips .filter-chip');
    deptChips.forEach(chip => {
      chip.addEventListener('click', () => {
        deptChips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeFilters.dept = chip.dataset.dept;
        applyFilters();
      });
    });

    const roleChips = document.querySelectorAll('#roleChips .filter-chip');
    roleChips.forEach(chip => {
      chip.addEventListener('click', () => {
        roleChips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeFilters.role = chip.dataset.role;
        applyFilters();
      });
    });

    const toggleBtn = document.getElementById('toggleFilters');
    const filterPanel = document.getElementById('filterPanel');

    if (toggleBtn && filterPanel) {
      toggleBtn.addEventListener('click', () => {
        filterPanel.classList.toggle('hidden');
      });
    }
  });
</script>

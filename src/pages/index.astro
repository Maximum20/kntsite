---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/navbar/navbar.astro";
import Hero from "../components/hero.astro";
import Footer from "../components/footer.astro";
---

<Layout title="Відділення променевої терапії">
  <main class="grid gap-20 mt-16 text-slate-800">
    <Hero />
    
    <!-- Технології (вже є у тебе) -->
    <section class="container mx-auto px-5">
      <div class="mt-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-center">Сучасні технології лікування</h2>
        <p class="text-lg mt-4 text-slate-600 text-center max-w-xl mx-auto">
          Використовуємо обладнання Elekta для досягнення найкращих результатів.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
        <!-- Твої картки про Точність, Швидкість, Безпеку -->
      </div>
    </section>

    <!-- НОВИЙ РОЗДІЛ: Етапи лікування -->
    <section class="bg-slate-50 py-16 px-5">
      <div class="container mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Як проходить лікування?</h2>
        <div class="grid md:grid-cols-4 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="text-blue-600 font-bold text-3xl mb-4">01</div>
            <h4 class="font-bold mb-2">Консультація</h4>
            <p class="text-sm text-slate-600">Огляд лікаря-радіолога та вивчення історії хвороби.</p>
          </div>
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="text-blue-600 font-bold text-3xl mb-4">02</div>
            <h4 class="font-bold mb-2">КТ-розмітка</h4>
            <p class="text-sm text-slate-600">Виготовлення фіксуючих засобів та топометрична підготовка.</p>
          </div>
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="text-blue-600 font-bold text-3xl mb-4">03</div>
            <h4 class="font-bold mb-2">Планування</h4>
            <p class="text-sm text-slate-600">Робота медичних фізиків над дозиметричним планом IMRT/VMAT.</p>
          </div>
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="text-blue-600 font-bold text-3xl mb-4">04</div>
            <h4 class="font-bold mb-2">Опромінення</h4>
            <p class="text-sm text-slate-600">Курс сеансів на лінійному прискорювачі під контролем IGRT.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer /> <!-- Тільки один раз! -->
</Layout>
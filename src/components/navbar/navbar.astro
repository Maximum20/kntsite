---
import Link from "@components/ui/link.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Image } from "astro:assets";
import fullLogo from "../../assets/full-logo.jpg";

const menuitems = [
  { title: "Про відділення", path: "/about" },
  { title: "Послуги", path: "/services" },
  { title: "Лікарі", path: "/doctors" },
  { title: "Контакти", path: "/contact" },
  { title: "На головну клініки", path: "https://dokod.org.ua/", external: true },
];
---

<div class="max-w-screen-2xl mx-auto px-5">
  <header class="flex flex-col lg:flex-row justify-between items-center my-5 gap-4">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center shrink-0">
          <Image 
            src={fullLogo} 
            alt="Логотип КНТ Дніпро" 
            class="h-10 md:h-14 lg:h-20 w-auto object-contain" 
            loading="eager"
            format="webp"
          />
        </a>
        
        <div class="block lg:hidden">
          <MenuIcon class="w-6 h-6 text-gray-800" />
        </div>
      </div>
      
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-8">
          {
            menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  target={item.external ? "_blank" : "_self"}
                  rel={item.external ? "noopener" : ""}
                  class:list={[
                    "flex lg:px-3 py-2 items-center font-medium transition text-sm group",
                    item.external 
                      ? "text-blue-500 hover:text-blue-700 italic" 
                      : "text-gray-600 hover:text-blue-600"
                  ]}>
                  <span>{item.title}</span>
                  
                  {item.external && (
                    <svg 
                      xmlns="http://www.w3.org/2000/svg" 
                      fill="none" 
                      viewBox="0 0 24 24" 
                      stroke-width="2.5" 
                      stroke="currentColor" 
                      class="w-3 h-3 ml-1 transition-transform duration-300 group-hover:-translate-y-1 group-hover:translate-x-1"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </MenuItems>
    </Astronav>

    <div class="hidden lg:flex items-center gap-4">
      <a href="tel:+380671234567" class="text-sm font-bold text-gray-700 hover:text-blue-600 whitespace-nowrap">
        +38 (067) 123-45-67
      </a>
      <Link href="/contact" size="sm">Записатися</Link>
    </div>
  </header>
</div>
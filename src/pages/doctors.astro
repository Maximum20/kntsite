---
import Layout from '../layouts/Layout.astro';
import DoctorCard from '../components/DoctorCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { Icon } from "astro-icon/components";
import { doctors } from '../data'; 
import TeamGallery from '@components/TeamGallery.astro';
---

<Layout title="Наша команда" hideSubNav={true}>
  <main class="min-h-screen py-8 px-4 md:px-8">
    
    <!-- Навігація як у прикладі -->
    <div class="relative z-20 px-2 md:px-12 flex items-center mb-12">
      <a href="/" class="inline-flex items-center gap-4 group">
        <div class="w-12 h-12 rounded-full backdrop-blur-xl bg-white/60 border border-white/80 flex items-center justify-center group-hover:bg-white/90 transition-all shadow-lg shadow-slate-200/40">
          <Icon name="bx:left-arrow-alt" class="w-6 h-6 text-slate-700 group-hover:-translate-x-1 transition-transform" />
        </div>
        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">На головну</span>
      </a>
    </div>

    <header class="text-center mb-12">
      <h1 class="font-serif text-5xl md:text-6xl font-bold text-[#1a365d] mb-6 tracking-tight">
        Наша велика команда
      </h1>
      <p class="text-[10px] md:text-xs font-bold tracking-[0.4em] text-slate-400 uppercase">
       
      </p>
    </header>

    <!-- Вставляємо наш новий компонент пошуку -->
    <SearchBar />

    <div class="container mx-auto">
      <div id="doctorsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 max-w-7xl mx-auto pb-20">
        {doctors.map(doctor => (
          <DoctorCard doctor={doctor} />
        ))}
      </div>

      <div id="noResults" class="hidden text-center py-20">
        <p class="text-slate-400 text-xl font-serif italic">Спеціалістів не знайдено...</p>
      </div>
    </div>

<TeamGallery />

  </main>
</Layout>



<script>
  function initCards() {
    const cards = document.querySelectorAll('.doctor-card');
    cards.forEach(card => {
      card.addEventListener('click', () => {
        if (card.classList.contains('is-expanded')) {
          card.classList.remove('is-expanded');
        } else {
          cards.forEach(c => c.classList.remove('is-expanded'));
          card.classList.add('is-expanded');
        }
      });
    });
  }
  initCards();
  document.addEventListener('astro:after-swap', initCards);
</script>


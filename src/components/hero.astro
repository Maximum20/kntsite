---
// src/components/hero.astro
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

// 1. Отримуємо дані, які прийдуть з index.astro
const { title, subtitle, description } = Astro.props;
---

{/* МІНЯЄМО max-w-screen-xl на max-w-[1850px] та збільшуємо відступи px */}
<main class="max-w-[1850px] mx-auto px-6 md:px-12 lg:px-20 pt-4 md:pt-20 pb-16 md:pb-32 font-sans relative overflow-visible">
  
  {/* Міняємо співвідношення сітки: 1fr для тексту і 1.3fr для картинки, щоб вона була БІЛЬШОЮ */}
  <div class="grid lg:grid-cols-[1fr_1.3fr] items-center gap-12 lg:gap-24 relative z-10 min-h-[600px]">
    
    <div class="text-center lg:text-left order-1 relative z-10">
  
      <div class="hidden sm:inline-flex items-center gap-2 bg-cyan-50 text-cyan-700 px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-[0.2em] border border-cyan-100 shadow-sm transition-transform hover:scale-105 select-none shrink-0 w-fit">
  <Icon name="bx:bxs-badge-check" class="w-5 h-5 text-cyan-600" />
  Передові технології лікування
</div>

<div class="hidden sm:inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-3.5 py-1.5 rounded-full text-[10px] md:text-[11px] font-bold uppercase tracking-widest border border-blue-100 shadow-sm transition-transform duration-300 transform hover:scale-105 select-none shrink-0 w-fit">
  <img src="/hero/nszu.png" alt="НСЗУ" class="h-4 md:h-5 w-auto object-contain" />
  Програма медичних гарантій
</div>

      <h1 class="text-4xl lg:text-6xl xl:text-7xl font-bold leading-[1.1] tracking-tight text-slate-900 relative z-20">
  {title} 
  {/* Просто прибираємо класи hidden lg:block, щоб перенос працював завжди */}
  <br /> 
  <span class="lg:hidden text-blue-600">м.Дніпро</span>
  <span class="hidden lg:inline text-blue-600">{subtitle}</span>
</h1>

      <div class="lg:hidden my-10 relative z-10">
         <div class="rounded-[2rem] overflow-hidden shadow-xl border-4 border-white bg-slate-50 relative z-10">
            <img src="/hero/raddepartment.jpg" alt="Будівля відділення" class="hero-dynamic-img h-auto w-full object-cover" />
         </div>
         
         <div class="hero-hug-trigger absolute -bottom-6 -right-2 bg-white/95 backdrop-blur-md py-3 px-4 rounded-[1.5rem] shadow-2xl border border-slate-100 max-w-[260px] animate-hero-float z-20 cursor-pointer active:scale-95">
            <div class="flex items-center gap-3 text-left pointer-events-none">
              <div class="w-10 h-10 shrink-0 bg-cyan-100 rounded-full flex items-center justify-center text-cyan-600 shadow-inner relative overflow-hidden">
                <div class="hero-heart-layer absolute inset-0 flex items-center justify-center transition-all duration-300">
                  <Icon name="bx:bxs-heart" class="w-6 h-6" />
                </div>
                <div class="hero-hug-layer absolute inset-0 flex items-center justify-center text-2xl opacity-0 scale-50 transition-all duration-300">🤗</div>
              </div>
              <div>
                <h4 class="font-bold text-slate-900 text-[11px] mb-0 tracking-tight text-balance">Турбота про кожного</h4>
                <p class="text-[9px] text-slate-500 leading-tight font-medium">Індивідуальні плани лікування та підтримка на кожному етапі.</p>
              </div>
            </div>
          </div>
      </div>
      
      <p class="text-base md:text-lg mt-6 text-slate-600 max-w-xl mx-auto lg:mx-0 leading-relaxed font-medium relative z-20">
        {description}
      </p>
      
      <div id="hero-buttons" class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start relative z-20 hidden">
  <a
    id="dynamic-btn"
    href="#"
    class="flex gap-2 items-center justify-center px-8 py-4 rounded-xl font-bold shadow-lg bg-slate-900 text-white transition-transform active:scale-95"
  >
    <Icon class="w-5 h-5" name="bx:bxs-chevron-right-circle" />
    <span id="dynamic-btn-text">Детальніше</span>
  </a>

  <a
    id="doctors-btn"
    href="/contact"
    class="flex gap-2 items-center justify-center px-8 py-4 rounded-xl font-bold border-2 border-slate-200 hover:bg-slate-50 transition-all active:scale-95 text-slate-700"
  >
    <Icon class="text-slate-700 w-5 h-5" name="bx:bxs-calendar" />
    <span id="doctors-btn-text">Наші лікарі</span>
  </a>
</div>

      <div class="mt-10 inline-flex items-center justify-between bg-white/40 backdrop-blur-md border border-white/60 py-3.5 px-8 md:py-4 md:px-12 rounded-[2.5rem] relative z-20 shadow-sm min-w-[280px] md:min-w-[400px]">
        <div class="flex flex-col text-left">
          <span class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tighter">15+</span>
          <span class="text-[9px] md:text-xs uppercase font-bold text-slate-500 tracking-widest mt-0.5">Років досвіду</span>
        </div>
        <div class="w-px h-10 bg-slate-300/60 mx-4"></div>
        <div class="flex flex-col text-left">
          <span class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tighter">1500+</span>
          <span class="text-[9px] md:text-xs uppercase font-bold text-slate-500 tracking-widest mt-0.5">Пацієнтів щорічно</span>
        </div>
      </div>
    </div>

    <div class="hidden lg:block relative order-2 z-10 w-full">
      <div class="relative transform lg:scale-110 transition-transform duration-500 hover:scale-[1.17] group">
        <div class="rounded-[2.5rem] overflow-hidden shadow-2xl border-8 border-white bg-slate-50 relative z-10 aspect-[4/3]">
          <img src="/hero/raddepartment.jpg" alt="Будівля відділення" class="hero-dynamic-img w-full h-full object-cover transition-opacity duration-500" />
        </div>
      </div>

      <div class="hero-hug-trigger absolute -bottom-10 -right-10 xl:-right-16 bg-white/95 backdrop-blur-md p-6 md:p-7 rounded-[2.5rem] shadow-2xl border border-slate-100 max-w-[280px] md:max-w-[320px] animate-hero-float z-30 transition-all duration-300 cursor-pointer active:scale-95 select-none overflow-hidden">
        <div class="flex items-start gap-4 text-left pointer-events-none">
          <div class="w-12 h-12 shrink-0 bg-cyan-100 rounded-full flex items-center justify-center text-cyan-600 shadow-inner relative overflow-hidden">
            <div class="hero-heart-layer absolute inset-0 flex items-center justify-center transition-all duration-300 opacity-100 scale-100">
              <Icon name="bx:bxs-heart" class="w-7 h-7" />
            </div>
            <div class="hero-hug-layer absolute inset-0 flex items-center justify-center text-4xl opacity-0 scale-50 transition-all duration-300 leading-none">🤗</div>
          </div>
          <div class="pr-2">
            <h4 class="font-bold text-slate-900 text-base mb-1 tracking-tight leading-tight">Турбота про кожного</h4>
            <p class="text-[12px] text-slate-500 leading-relaxed font-medium">Індивідуальні плани лікування та підтримка на кожному етапі.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<style>
  @keyframes hero-float-anim {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  
  .animate-hero-float {
    animation: hero-float-anim 5s ease-in-out infinite;
  }
</style>

<script>


  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll<HTMLElement>('.hero-hug-trigger');
    cards.forEach(card => {
      const heart = card.querySelector<HTMLElement>('.hero-heart-layer');
      const hug = card.querySelector<HTMLElement>('.hero-hug-layer');
      if (heart && hug) {
        card.addEventListener('click', () => {
          heart.style.opacity = '0';
          heart.style.transform = 'scale(0)';
          hug.style.opacity = '1';
          hug.style.transform = 'scale(1.4)';
          setTimeout(() => {
            heart.style.opacity = '1';
            heart.style.transform = 'scale(1)';
            hug.style.opacity = '0';
            hug.style.transform = 'scale(0.5)';
          }, 1500);
        });
      }
    });
  });
</script>
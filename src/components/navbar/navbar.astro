---
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import { Image } from "astro:assets";
import fullLogo from "../../assets/full-logo.jpg";

const menuitems = [
  { title: "Про відділення", path: "/about" },
  { title: "Послуги", path: "/services" },
  { title: "Лікарі", path: "/doctors" },
  { title: "Контакти", path: "/contact" },
  { title: "На головну клініки", path: "https://dokod.org.ua/", external: true },
];
---

<div class="max-w-screen-2xl mx-auto px-5 font-sans">
  <header class="flex flex-col lg:flex-row items-center py-6 gap-4">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center shrink-0">
          <Image 
            src={fullLogo} 
            alt="Логотип КНТ Дніпро" 
            class="h-12 md:h-14 lg:h-18 w-auto object-contain" 
            loading="eager"
            format="webp"
          />
        </a>
        
        <div class="flex items-center gap-3 lg:hidden">
          <!-- Кнопка просто скролить вниз -->
          <a href="#contacts" class="text-blue-600 bg-blue-50 border border-blue-100 rounded-full px-4 py-2 flex items-center gap-2 font-bold text-xs transition-all active:scale-95 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Зв'язок
          </a>
          <MenuIcon class="w-8 h-8 text-slate-800" />
        </div>
      </div>
      
      <MenuItems class="hidden w-full lg:w-auto mt-4 lg:flex lg:mt-0 lg:ml-auto">
        <ul class="flex flex-col lg:flex-row lg:gap-5 xl:gap-8 items-center">
          {menuitems.map((item) => (
            <li>
              <a
                href={item.path}
                target={item.external ? "_blank" : "_self"}
                rel={item.external ? "noopener" : ""}
                class:list={[
                  "flex lg:px-2 py-2 items-center font-bold transition text-[15px] tracking-tight group",
                  item.external 
                    ? "text-blue-600 hover:text-blue-800 italic" 
                    : "text-slate-600 hover:text-blue-600"
                ]}>
                <span>{item.title}</span>
                {item.external && (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5 ml-1.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
                  </svg>
                )}
              </a>
            </li>
          ))}
          
          <li class="hidden lg:block ml-2">
            <a href="#contacts" class="flex items-center gap-2 font-bold text-blue-600 hover:bg-blue-50 px-4 py-2 rounded-full transition-all text-[15px]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Зв'язок
            </a>
          </li>
        </ul>
      </MenuItems>
    </Astronav>
  </header>
</div>
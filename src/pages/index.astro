---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero.astro";
import News from "../components/news.astro";
import { Icon } from "astro-icon/components";
import Contacts from "../components/contacts.astro";

import { departments, iconMap } from "../data/departments";
import TechSection from "../components/TechSection.astro";
---

<Layout title="Відділення променевої терапії">
  <main class="font-sans relative">
    
    <div id="dynamic-zone" class="transition-opacity duration-500 pt-4 md:pt-6">
      <Hero 
  title={departments[0].title} 
  subtitle={departments[0].subtitle} 
  description={departments[0].description} 
/>

      <TechSection departments={departments} />
    </div>

    <Contacts />

    <News />

  </main>
</Layout>

<script define:vars={{ departments, iconMap }}>
  const buttons = document.querySelectorAll('.dept-btn');
  const logoTrigger = document.querySelector('.logo-home-trigger');
  const dynamicZone = document.getElementById('dynamic-zone');

// Попереднє завантаження всіх фото відділень
window.addEventListener('DOMContentLoaded', () => {
  departments.forEach(dept => {
    if (dept.image) {
      const img = new Image();
      img.src = dept.image;
    }
  });
});



function updateContent(targetId) {
    const data = departments.find(d => d.id === targetId);
    if (!data) return;

  // --- КРОК А: МІНЯЄМО ФОТО ВІДРАЗУ ---
  // Робимо це до setTimeout, щоб у браузера було 300мс фори, поки зона прозора
  const heroImages = document.querySelectorAll('.hero-dynamic-img');
  heroImages.forEach(img => {
    if (data.image) {
      img.src = data.image;
    }
  });

  // Ховаємо текстову зону
  dynamicZone.style.opacity = '0';
  dynamicZone.style.transform = 'translateY(10px)';

  setTimeout(() => {
    // --- КРОК Б: ОНОВЛЮЄМО ТЕКСТИ ТА ІКОНКИ (через 300мс) ---
    const h1 = document.querySelector('h1');
    if (h1) h1.innerHTML = `${data.title} <br/> <span class="text-blue-600">${data.subtitle || ''}</span>`;
    
    const heroP = document.querySelector('h1 + div + p') || document.querySelector('h1 + p');
    if (heroP) heroP.textContent = data.description;

    const tTitle = document.getElementById('tech-title');
    const tDesc = document.getElementById('tech-desc');
    const tGrid = document.getElementById('tech-grid');


    // --- НОВИЙ БЛОК ДЛЯ КНОПОК ---
        const buttonsContainer = document.getElementById('hero-buttons');
        const mainBtn = document.getElementById('dynamic-btn');
        const mainBtnText = document.getElementById('dynamic-btn-text');

        if (buttonsContainer && mainBtn && mainBtnText) {
            if (targetId === 'home') {
                // Сховуємо кнопки, коли ми на головній
                buttonsContainer.classList.add('hidden');
                buttonsContainer.classList.remove('flex');
            } else {
                // Показуємо кнопки для конкретних розділів
                buttonsContainer.classList.remove('hidden');
                buttonsContainer.classList.add('flex');
                
                // Оновлюємо посилання та текст
                mainBtn.href = `/services/${targetId}`; 
                mainBtnText.textContent = `Цікавинки відділення`;
            }
        }


    if (tTitle) {
      tTitle.textContent = targetId === 'home' ? "Наші переваги та можливості" : data.title;
    }
   // Шукай це всередині setTimeout у функції updateContent
if (tDesc) {
  if (targetId === 'home') {
    tDesc.textContent = "У нас є все — від поверхневого лікування шкіри до складних операцій на внутрішніх органах";
  } else {
    tDesc.textContent = data.description;
  }
}
    if (tGrid) {
      tGrid.innerHTML = data.features.map(f => `
        <div class="animate-in">
           <div class="rounded-full ${f.bg} p-4 w-16 h-16 mx-auto flex items-center justify-center ${f.color} shadow-sm border border-white/50">
             <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">${iconMap[f.icon] || ''}</svg>
           </div>
           <h3 class="font-bold text-xl mt-4 tracking-tight text-slate-900">${f.title}</h3>
           <p class="text-slate-500 mt-2 text-sm italic leading-relaxed">${f.desc}</p>
        </div>
      `).join('');
    }

    // Показуємо оновлений контент
    dynamicZone.style.opacity = '1';
    dynamicZone.style.transform = 'translateY(0)';
  }, 300);
}

  // Кліки по кнопках
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('active', 'bg-blue-600', 'text-white', 'shadow-lg');
        b.classList.add('text-slate-600');
      });
      btn.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
      btn.classList.remove('text-slate-600');
      updateContent(btn.dataset.target);
    });
  });

  // Клік по лого
  logoTrigger?.addEventListener('click', (e) => {
    e.preventDefault();
    buttons.forEach(b => {
      b.classList.remove('active', 'bg-blue-600', 'text-white', 'shadow-lg');
      b.classList.add('text-slate-600');
    });
    updateContent('home');
  });

  // Старт
  window.addEventListener('DOMContentLoaded', () => {
    updateContent('home');
  });
</script>
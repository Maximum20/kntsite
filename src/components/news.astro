---
import { getCollection } from 'astro:content';
import { Icon } from "astro-icon/components";

// Отримуємо новини. Якщо колекція ще не завантажилась, повертаємо порожній масив
const allNews = await getCollection('news') || [];
const sortedNews = allNews.sort((a, b) => Date.parse(b.data.date) - Date.parse(a.data.date));
---

<section id="news" class="container mx-auto px-5 py-20 scroll-mt-20">
  <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
    <div class="text-left">
      <h2 class="text-4xl lg:text-5xl font-bold text-slate-900 tracking-tight">Новини відділення</h2>
      <p class="text-lg mt-4 text-slate-600 font-medium">Останні оновлення нашого центру.</p>
    </div>
    
    <div class="flex items-center gap-2 bg-slate-50 border border-slate-100 p-2 rounded-2xl shadow-sm">
      <Icon name="bx:bxl-facebook-circle" class="w-6 h-6 text-blue-600" />
      <Icon name="bx:bxl-instagram-alt" class="w-6 h-6 text-pink-600" />
      <span class="text-[10px] uppercase font-bold text-slate-400 px-2 border-l border-slate-200">Sync Active</span>
    </div>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
    {sortedNews.map(item => (
      <div class="group bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500">
        <div class="aspect-video overflow-hidden">
          {item.data.image && (
            <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          )}
        </div>
        <div class="p-8">
          <div class="flex items-center gap-2 text-blue-600 font-bold text-xs mb-4 uppercase">
            <Icon name="bx:calendar" class="w-4 h-4" /> {item.data.date}
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-4 leading-tight group-hover:text-blue-600 transition-colors">
            {item.data.title}
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-6 font-medium">
            {item.data.description}
          </p>
          <button class="flex items-center gap-2 font-bold text-sm text-slate-900 group/btn">
            Детальніше 
            <Icon name="bx:right-arrow-alt" class="w-5 h-5 transition-transform group-hover/btn:translate-x-1" />
          </button>
        </div>
      </div>
    ))}
  </div>
</section>
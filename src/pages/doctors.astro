---
import Layout from '../layouts/Layout.astro';
import { Icon } from "astro-icon/components";

const doctors = [
  {
    name: "Тетяна",
    surname: "Трубіцина",
    role: "Лікар-радіолог",
    initials: "ТТ",
    bio: "Експерт у галузі сучасної променевої терапії з досвідом лікування складних онкологічних патологій.",
    image: "/hero/doctors/snizhynska.png",
    experience: "15 років",
    specializations: ["Променева терапія", "Онкологія", "IMRT/VMAT"],
    education: "Національний медичний університет, PhD",
    achievements: "Понад 500 успішних курсів лікування",
    color: "from-blue-500 to-cyan-500"
  },
  {
    name: "Вікторія",
    surname: "Сніжинська",
    role: "Медичний фізик",
    initials: "ВС",
    bio: "Спеціаліст з дозиметричного планування та забезпечення точності опромінення на системах Elekta.",
    image: "/hero/doctors/trubitsyna.png",
    experience: "12 років",
    specializations: ["Дозиметрія", "Планування терапії", "Контроль якості"],
    education: "КНУ ім. Шевченка, фізика",
    achievements: "Сертифікація Elekta, IAEA",
    color: "from-purple-500 to-pink-500"
  },
  {
    name: "Євгеній",
    surname: "Підмогильний",
    role: "Радіаційний онколог",
    initials: "ЄП",
    bio: "Спеціаліст з сучасних методик опромінення IMRT та VMAT під контролем Brainlab.",
    image: "/hero/doctors/trubitsyna.png",
    experience: "18 років",
    specializations: ["IMRT", "VMAT", "Brainlab навігація"],
    education: "Харківський медуніверситет",
    achievements: "Міжнародні стажування в Німеччині",
    color: "from-emerald-500 to-teal-500"
  },
  {
    name: "Олена",
    surname: "Коваленко",
    role: "Онколог",
    initials: "ОК",
    bio: "Понад 15 років досвіду в клінічній онкології.",
    image: "/hero/doctors/snizhynska.png",
    experience: "15 років",
    specializations: ["Клінічна онкологія", "Хіміотерапія"],
    education: "Львівський медуніверситет",
    achievements: "Автор 20+ наукових публікацій",
    color: "from-orange-500 to-amber-500"
  },
  {
    name: "Максим",
    surname: "Павленко",
    role: "Медичний фізик",
    initials: "МП",
    bio: "Забезпечення технічної точності променевої терапії.",
    image: "/hero/doctors/trubitsyna.png",
    experience: "10 років",
    specializations: ["Калібрування обладнання", "QA/QC"],
    education: "КПІ, медична фізика",
    achievements: "Впровадження нових протоколів безпеки",
    color: "from-indigo-500 to-blue-500"
  },
  {
    name: "Сергій",
    surname: "Лисенко",
    role: "Радіолог",
    initials: "СЛ",
    bio: "Спеціалізується на томосинтезі та цифровій радіографії.",
    image: "/hero/doctors/snizhynska.png",
    experience: "14 років",
    specializations: ["Томосинтез", "КТ", "МРТ"],
    education: "Одеський медуніверситет",
    achievements: "Діагностика ранніх стадій онкології",
    color: "from-rose-500 to-pink-500"
  },
];
---

<Layout title="Наші фахівці">
  <main class="relative h-screen w-full flex flex-col font-['Bricolage_Grotesque_Variable'] overflow-hidden bg-transparent">

    <!-- Main Carousel -->
    <div class="flex-1 flex items-center justify-center px-4 md:px-10 pt-6 md:pt-10 pb-[140px] sm:pb-[160px] md:pb-[180px] relative z-10">
      <div class="swiper main-swiper w-full max-w-[1600px] h-[450px] sm:h-[500px] md:h-[550px] lg:h-[600px] perspective">
        <div class="swiper-wrapper">
          {doctors.map((doc, index) => (
            <div class="swiper-slide">
              <div class="doctor-card-wrapper h-full flex items-center justify-center" data-color={doc.color}>

                <!-- Card Background with Initials -->
                <div class="doctor-card group relative w-full max-w-5xl h-full transition-all duration-700 ease-out">

                  <!-- Floating Initials Background -->
                  <div class="absolute inset-0 flex items-center justify-start pl-4 md:pl-12 overflow-hidden pointer-events-none">
                    <span class="text-[180px] md:text-[280px] lg:text-[380px] font-black text-slate-100 leading-none tracking-tighter uppercase">{doc.initials}</span>
                  </div>

                  <!-- Card Content Grid -->
                  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[1fr_1fr] h-full p-6 md:p-10 lg:p-12 gap-8 md:gap-12">

                    <!-- Left Column: Text Info -->
                    <div class="flex flex-col justify-center space-y-4 md:space-y-6 relative order-2 lg:order-1">

                      <!-- Name -->
                      <div class="space-y-1 md:space-y-2">
                        <h2 class="text-4xl md:text-6xl lg:text-7xl font-black text-slate-900 leading-[0.95] tracking-tight uppercase italic">
                          {doc.name}
                        </h2>
                        <h3 class="text-3xl md:text-5xl lg:text-6xl font-black text-blue-600 leading-[0.95] tracking-tight uppercase">
                          {doc.surname}
                        </h3>
                      </div>

                      <!-- Role Badge -->
                      <div class="flex items-center gap-2 md:gap-3 pt-2 md:pt-4">
                        <div class="h-0.5 md:h-1 w-8 md:w-12 bg-blue-600 rounded-full"></div>
                        <span class="text-blue-600 font-bold uppercase tracking-[0.2em] md:tracking-[0.3em] text-xs md:text-sm">{doc.role}</span>
                      </div>

                      <!-- Bio -->
                      <p class="text-slate-500 text-sm md:text-base lg:text-lg leading-relaxed font-light max-w-xl italic">
                        "{doc.bio}"
                      </p>

                      <!-- Specializations Pills -->
                      <div class="flex flex-wrap gap-2 pt-2">
                        {doc.specializations.slice(0, 3).map(spec => (
                          <span class="px-3 md:px-4 py-1.5 md:py-2 bg-blue-50 text-blue-700 rounded-full text-xs md:text-sm font-semibold transition-all duration-300 hover:scale-105 hover:bg-blue-100">
                            {spec}
                          </span>
                        ))}
                      </div>

                      <!-- Action Button -->
                      <div class="pt-4">
                        <button class="bg-blue-600 text-white px-6 md:px-8 py-3 md:py-4 rounded-xl md:rounded-2xl font-bold transition-all duration-500 hover:scale-105 hover:shadow-xl hover:bg-blue-700 text-sm md:text-base">
                          Записатися на прийом
                        </button>
                      </div>
                    </div>

                    <!-- Right Column: Image -->
                    <div class="flex items-center justify-center relative order-1 lg:order-2">
                      <!-- Doctor Image Card -->
                      <div class="doctor-image-container relative group/img">
                        <div class="relative w-[200px] h-[280px] md:w-[280px] md:h-[390px] lg:w-[320px] lg:h-[450px] rounded-[2rem] md:rounded-[2.5rem] overflow-hidden shadow-2xl border-[8px] md:border-[12px] border-white transition-all duration-700 group-hover:scale-105 group-hover:shadow-3xl">
                          <img
                            src={doc.image}
                            alt={doc.name}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110"
                          />

                          <!-- Image Overlay Gradient -->
                          <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
                        </div>

                        <!-- Floating Glow Effect -->
                        <div class={`absolute -inset-4 bg-gradient-to-br ${doc.color} opacity-0 group-hover:opacity-20 blur-2xl -z-10 transition-all duration-700 rounded-[3rem]`}></div>
                      </div>
                    </div>

                  </div>
                </div>

              </div>
            </div>
          ))}
        </div>

        <!-- Navigation Arrows -->
        <button class="swiper-button-prev nav-button-light nav-prev hidden md:flex">
          <Icon name="bx:chevron-left" class="size-6 md:size-8" />
        </button>
        <button class="swiper-button-next nav-button-light nav-next hidden md:flex">
          <Icon name="bx:chevron-right" class="size-6 md:size-8" />
        </button>
      </div>
    </div>

    <!-- Bottom Thumbnail Navigation -->
    <div class="fixed bottom-0 left-0 right-0 z-50 min-h-[220px] flex items-center bg-white/80 backdrop-blur-2xl border-t border-slate-200/50 shadow-[0_-20px_50px_-20px_rgba(0,0,0,0.15)]">
  <div class="swiper thumb-swiper w-full max-w-[1400px] mx-auto !overflow-visible py-12">
    <div class="swiper-wrapper flex items-center">
      {doctors.map((doc, index) => (
        <div class="swiper-slide !w-auto px-6 md:px-10"> <div class="thumb-card cursor-pointer transition-all duration-500 group/thumb">
            <div class="relative">
              <div class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full overflow-hidden border-4 border-white shadow-xl transition-all duration-500 thumb-image bg-slate-100">
                <img src={doc.image} alt={doc.name} class="w-full h-full object-cover" />
              </div>
              <div class={`absolute -inset-4 bg-gradient-to-br ${doc.color} opacity-0 blur-2xl -z-10 transition-all duration-600 rounded-full thumb-glow`}></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>


  </main>
</Layout>

<style is:global>
  @import url('https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css');
  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@300;400;600;700;800&display=swap');

  /* Navigation Buttons */
  .nav-button-light {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 1.5rem;
    color: #64748b;
    transition: all 0.3s ease;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .nav-button-light:hover {
    background: rgba(255, 255, 255, 1);
    color: #2563eb;
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 8px 30px rgba(37, 99, 235, 0.2);
  }

  .nav-prev { left: 10px; }
  .nav-next { right: 10px; }

  @media (min-width: 1024px) {
    .nav-prev { left: -80px; }
    .nav-next { right: -80px; }
  }


.thumb-image {
  /* Додаємо transform-origin, щоб воно росло з центру рівномірно */
  transform-origin: center center;
  will-change: transform;
}

/* Переконайся, що активна аватарка не має зайвих обрізань */
.swiper-slide-thumb-active .thumb-image {
  transform: scale(1.22);
  border-color: #2563eb !important;
  box-shadow: 0 10px 30px rgba(37, 99, 235, 0.4) !important;
}


/* Додатково для мобілок, щоб не було тісно */
@media (max-width: 768px) {
  .thumb-swiper {
    padding-top: 2rem !important;
    padding-bottom: 2rem !important;
  }
}
  .swiper-slide-thumb-active .thumb-glow {
    opacity: 0.7 !important;
  }

  /* Hover effect for thumbnails */
  .thumb-card:hover .thumb-image {
    transform: scale(1.1);
  }

  .swiper-slide-thumb-active .thumb-card:hover .thumb-image {
    transform: scale(1.45);
  }

  /* Mobile Responsive Adjustments */
  @media (max-width: 768px) {
    .swiper-slide-thumb-active .thumb-image {
      transform: scale(1.35);
    }

    .swiper-slide-thumb-active .thumb-card:hover .thumb-image {
      transform: scale(1.4);
    }
  }

  /* Swiper Custom Styles */
  .swiper-slide {
    opacity: 0.4 !important;
    transition: opacity 0.7s ease;
  }

  .swiper-slide-active {
    opacity: 1 !important;
  }

  /* Perspective for 3D effect */
  .perspective {
    perspective: 2000px;
  }

  /* Magnetic Effect Helper */
  .doctor-card {
    transform-style: preserve-3d;
  }

  /* Prevent body scroll/overflow */
  html, body {
    overflow-x: hidden;
    overflow-y: auto;
    max-width: 100vw;
    position: relative;
  }

  main {
    max-width: 100vw;
    position: relative;
    min-height: 100vh;
    min-height: 100dvh; /* Dynamic viewport height for mobile */
  }

  * {
    -webkit-tap-highlight-color: transparent;
  }

  /* Swiper responsive fixes */
  .swiper {
    width: 100%;
    max-width: 100%;
  }

  .swiper-wrapper {
    align-items: center;
  }

  /* Improve touch targets on mobile */
  @media (max-width: 768px) {
    .thumb-card {
      padding: 4px;
    }
  }

  /* Landscape mobile adjustments */
  @media (max-height: 600px) and (orientation: landscape) {
    .main-swiper {
      height: 400px !important;
    }

    .doctor-card {
      height: 350px !important;
    }
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script is:inline define:vars={{ doctors }}>
  function initGlassmorphicCarousel() {
    let mainSwiper, thumbSwiper;

    // 1. Твоя ініціалізація нижніх аватарок (лишаємо як було)
    thumbSwiper = new Swiper(".thumb-swiper", {
      spaceBetween: 12,
      slidesPerView: "auto",
      centeredSlides: true,
      slideToClickedSlide: true,
      watchSlidesProgress: true,
      freeMode: false,
      breakpoints: {
        640: { spaceBetween: 16 },
        768: { spaceBetween: 20 },
        1024: { spaceBetween: 24 }
      }
    });

    // 2. Твоя ініціалізація великих карток
    mainSwiper = new Swiper(".main-swiper", {
      effect: "creative",
      speed: 1200,
      creativeEffect: {
        prev: { translate: ["-120%", 0, -500], rotate: [0, 0, -15], opacity: 0 },
        next: { translate: ["120%", 0, -500], rotate: [0, 0, 15], opacity: 0 },
      },
      grabCursor: true,
      touchRatio: 1,
      navigation: {
        nextEl: ".nav-next",
        prevEl: ".nav-prev",
      },
      // Зв'язок: низ керує верхом
      thumbs: {
        swiper: thumbSwiper
      },
      keyboard: { enabled: true },
      on: {
        // ОСЬ ТУТ МАГІЯ: верх керує низом
        slideChange: function() {
          // Змушуємо нижній слайдер їхати за верхнім
          thumbSwiper.slideTo(this.activeIndex);
          
          // Твій консоль лог
          console.log('Current slide:', this.activeIndex + 1);
        }
      }
    });

    // Магнітний ефект (твій код без змін)
    if (window.innerWidth >= 1024) {
      const cards = document.querySelectorAll('.doctor-card');
      cards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const rotateX = (e.clientY - rect.top - rect.height / 2) / 20;
          const rotateY = (rect.width / 2 - (e.clientX - rect.left)) / 20;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
        });
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initGlassmorphicCarousel);
  document.addEventListener('astro:page-load', initGlassmorphicCarousel);
</script>
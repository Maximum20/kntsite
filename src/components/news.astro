---
import { getCollection } from 'astro:content';
import { Icon } from "astro-icon/components";
import { Image } from 'astro:assets'; 

const allNews = await getCollection('news') || [];
const latestNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section id="news" class="container mx-auto px-6 py-24 scroll-mt-20">
  <!-- Header -->
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 border-b border-slate-100 pb-8">
    <div class="max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-4">
        Новини <span class="text-blue-600">відділення</span>
      </h2>
      <p class="text-lg text-slate-500 font-medium">
        Дізнавайтеся першими про нові технології та події нашого центру.
      </p>
    </div>
    
    <a href="/all-news" class="mt-6 md:mt-0 group flex items-center gap-2 px-5 py-2.5 bg-white border-2 border-slate-900 text-slate-900 rounded-full font-bold hover:bg-slate-900 hover:text-white transition-all duration-300">
      Архів публікацій
      <Icon name="bx:chevron-right" class="w-5 h-5 transition-transform group-hover:translate-x-1" />
    </a>
  </div>

  <!-- News Grid -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
    {latestNews.map(item => (
      <article class="group bg-white rounded-3xl border border-slate-100 overflow-hidden hover:border-blue-100 hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 flex flex-col">
        {/* Image Container */}
        <div class="aspect-[16/10] overflow-hidden relative">
          {item.data.image && (
            <Image 
              src={item.data.image} 
              alt={item.data.title} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
            />
          )}
          <div class="absolute top-4 left-4">
            <span class="bg-white/90 backdrop-blur-md text-slate-900 text-[11px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
              Новина
            </span>
          </div>
        </div>

        {/* Content */}
        <div class="p-8 flex flex-col flex-grow">
          <div class="flex items-center gap-2 text-blue-600 font-bold text-[11px] mb-4 uppercase tracking-widest">
            <Icon name="bx:calendar" class="w-4 h-4" /> 
            {item.data.date.toLocaleDateString('uk-UA')}
          </div>
          
          <h3 class="text-xl font-bold text-slate-900 mb-4 leading-tight group-hover:text-blue-600 transition-colors line-clamp-2">
            {item.data.title}
          </h3>
          
          <p class="text-slate-500 text-sm leading-relaxed mb-8 line-clamp-3">
            {item.data.description}
          </p>
          
          <div class="mt-auto">
            <a href={`/news/${item.id}`} class="inline-flex items-center gap-2 text-sm font-bold text-slate-900 group/link">
              <span class="relative">
                Читати повністю
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-blue-600 transition-all duration-300 group-hover/link:w-full"></span>
              </span>
              <Icon name="bx:right-arrow-alt" class="w-5 h-5 transition-transform group-hover/link:translate-x-1" />
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
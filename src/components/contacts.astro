---
// src/components/Contacts.astro
import { Icon } from "astro-icon/components";
---

<section id="contacts" class="container mx-auto px-5 py-20 scroll-mt-48 relative overflow-hidden">
  <!-- Floating background shapes -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="floating-shape shape-1"></div>
    <div class="floating-shape shape-2"></div>
    <div class="floating-shape shape-3"></div>
    <div class="floating-shape shape-4"></div>
    <div class="floating-shape shape-5"></div>
  </div>

  <!-- Main heading with animated gradient -->
  <div class="text-center mb-16">
    <h2 class="text-5xl md:text-7xl font-bold mb-6 tracking-tighter relative inline-block">
      <span class="gradient-text">Наші контакти</span>
      <div class="absolute -bottom-4 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-sky-400 to-transparent animate-pulse"></div>
    </h2>
    <p class="text-slate-600 text-lg max-w-2xl mx-auto">
      Оберіть зручний для вас спосіб зв'язку
    </p>
  </div>

  <!-- Contact cards grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">

    <!-- Phones Card -->
    <div class="glass-card group hover-lift">
      <div class="card-glow"></div>
      <div class="relative z-10">
        <!-- Card Header -->
        <div class="flex items-center gap-4 mb-8">
          <div class="icon-wrapper bg-gradient-to-br from-sky-400 to-blue-500">
            <Icon name="bx:phone" class="w-7 h-7 text-white icon-float" />
          </div>
          <div>
            <h3 class="font-bold text-xl text-slate-800">Реєстратура</h3>
            <p class="text-sm text-sky-600">Зателефонуйте нам</p>
          </div>
        </div>

        <!-- Phone numbers -->
        <div class="space-y-3">
          {[
            "(056) 720-79-01",
            "(066) 290-44-91",
            "(093) 958-55-67",
            "(068) 001-55-15"
          ].map((phone, index) => (
            <div class="phone-item group/phone" data-phone={phone} style={`--delay: ${index * 0.1}s`}>
              <a href={`tel:${phone}`} class="phone-link">
                <Icon name="bx:phone-call" class="w-5 h-5 text-sky-500 group-hover/phone:rotate-12 transition-transform" />
                <span class="font-semibold text-slate-700">{phone}</span>
              </a>
              <button class="copy-btn" data-copy={phone} aria-label="Копіювати">
                <Icon name="bx:copy" class="w-4 h-4 copy-icon" />
                <Icon name="bx:check" class="w-4 h-4 check-icon" />
              </button>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Address & Email Card -->
    <div class="glass-card group hover-lift">
      <div class="card-glow"></div>
      <div class="relative z-10">
        <!-- Card Header -->
        <div class="flex items-center gap-4 mb-8">
          <div class="icon-wrapper bg-gradient-to-br from-cyan-400 to-teal-500">
            <Icon name="bx:map" class="w-7 h-7 text-white icon-float" />
          </div>
          <div>
            <h3 class="font-bold text-xl text-slate-800">Локація</h3>
            <p class="text-sm text-cyan-600">Адреса та пошта</p>
          </div>
        </div>

        <!-- Email -->
        <div class="email-item mb-6" data-email="linac_olt1@ukr.net">
          <a href="mailto:linac_olt1@ukr.net" class="email-link">
            <Icon name="bx:envelope" class="w-5 h-5 text-cyan-500" />
            <span class="font-semibold text-slate-700 break-all">linac_olt1@ukr.net</span>
          </a>
          <button class="copy-btn" data-copy="linac_olt1@ukr.net" aria-label="Копіювати email">
            <Icon name="bx:copy" class="w-4 h-4 copy-icon" />
            <Icon name="bx:check" class="w-4 h-4 check-icon" />
          </button>
        </div>

        <!-- Address -->
        <a
          href="https://maps.google.com"
          target="_blank"
          class="address-card"
        >
          <div class="flex items-start gap-3 mb-3">
            <Icon name="bx:map-pin" class="w-6 h-6 text-teal-500 mt-1 flex-shrink-0 pulse-icon" />
            <div>
              <p class="font-medium text-slate-700 leading-relaxed">
                м. Дніпро, вул. Космічна, 21
              </p>
              <p class="text-sm text-slate-600">КНТ "ДОКОД" ДОР</p>
            </div>
          </div>
          <div class="map-link">
            <Icon name="bx:navigation" class="w-4 h-4" />
            <span>Маршрут на картах</span>
            <Icon name="bx:right-arrow-alt" class="w-5 h-5 arrow-icon" />
          </div>
        </a>
      </div>
    </div>

    <!-- Social Media Card -->
    <div class="glass-card group hover-lift">
      <div class="card-glow"></div>
      <div class="relative z-10">
        <!-- Card Header -->
        <div class="flex items-center gap-4 mb-8">
          <div class="icon-wrapper bg-gradient-to-br from-violet-400 to-purple-500">
            <Icon name="bx:chat" class="w-7 h-7 text-white icon-float" />
          </div>
          <div>
            <h3 class="font-bold text-xl text-slate-800">Соціальні мережі</h3>
            <p class="text-sm text-violet-600">Слідкуйте за нами</p>
          </div>
        </div>

        <!-- Social Links -->
        <div class="grid grid-cols-3 gap-3 mb-6">
          <a href="https://t.me/dokod_dp" target="_blank" class="social-btn telegram">
            <Icon name="bx:bxl-telegram" class="w-6 h-6" />
            <span class="social-label">Telegram</span>
          </a>
          <a href="https://www.facebook.com/kz.kod.dor" target="_blank" class="social-btn facebook">
            <Icon name="bx:bxl-facebook" class="w-6 h-6" />
            <span class="social-label">Facebook</span>
          </a>
          <a href="https://www.instagram.com/dokod.dp/" target="_blank" class="social-btn instagram">
            <Icon name="bx:bxl-instagram" class="w-6 h-6" />
            <span class="social-label">Instagram</span>
          </a>
          <a href="https://www.youtube.com/@DOKOD_DP" target="_blank" class="social-btn youtube">
            <Icon name="bx:bxl-youtube" class="w-6 h-6" />
            <span class="social-label">YouTube</span>
          </a>
          <a href="https://www.tiktok.com/@dokod.dp" target="_blank" class="social-btn tiktok">
            <Icon name="bx:bxl-tiktok" class="w-6 h-6" />
            <span class="social-label">TikTok</span>
          </a>
          <div class="social-btn more-soon">
            <Icon name="bx:dots-horizontal-rounded" class="w-6 h-6" />
            <span class="social-label">Скоро</span>
          </div>
        </div>

        <!-- Info Banner -->
        <div class="info-banner">
          <Icon name="bx:info-circle" class="w-5 h-5 text-violet-500" />
          <p class="text-sm text-slate-700">
            Завжди на зв'язку! Оберіть будь-який зручний канал комунікації.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom CTA Banner -->
  <div class="cta-banner">
    <div class="cta-content">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-sky-400 to-blue-500 flex items-center justify-center">
          <Icon name="bx:support" class="w-8 h-8 text-white" />
        </div>
        <div>
          <h3 class="text-2xl font-bold text-slate-800 mb-1">Потрібна консультація?</h3>
          <p class="text-slate-600">Ми готові відповісти на всі ваші запитання у будь-який зручний час</p>
        </div>
      </div>
      <a href="tel:+380567207901" class="cta-button">
        <Icon name="bx:phone-call" class="w-5 h-5" />
        <span>Передзвоніть мені</span>
      </a>
    </div>
  </div>

  
</section>

<style>
  /* Base Styles */
  

 

  /* Gradient Text */
  .gradient-text {
    background: linear-gradient(135deg,
      #0ea5e9 0%,
      #3b82f6 25%,
      #6366f1 50%,
      #8b5cf6 75%,
      #0ea5e9 100%
    );
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientFlow 8s ease infinite;
  }

  @keyframes gradientFlow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

 

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg) scale(1);
    }
    33% {
      transform: translate(30px, -30px) rotate(120deg) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) rotate(240deg) scale(0.9);
    }
  }

  /* Glass Card */
  .glass-card {
    position: relative;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-radius: 32px;
    padding: 2rem;
    border: 2px solid rgba(255, 255, 255, 0.8);
    box-shadow:
      0 8px 32px rgba(14, 165, 233, 0.1),
      0 2px 8px rgba(59, 130, 246, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transition: left 0.6s;
  }

  .glass-card:hover::before {
    left: 100%;
  }

  .card-glow {
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, #0ea5e9, #3b82f6, #6366f1);
    border-radius: 32px;
    opacity: 0;
    filter: blur(20px);
    transition: opacity 0.4s;
    z-index: -1;
  }

  .glass-card:hover .card-glow {
    opacity: 0.3;
  }

  .hover-lift {
    transform: translateY(0);
  }

  .glass-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow:
      0 20px 60px rgba(14, 165, 233, 0.2),
      0 8px 16px rgba(59, 130, 246, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  /* Icon Wrapper */
  .icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 8px 16px rgba(14, 165, 233, 0.3),
      inset 0 -2px 8px rgba(0, 0, 0, 0.1);
    position: relative;
    overflow: hidden;
  }

  .icon-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.3));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .glass-card:hover .icon-wrapper::before {
    opacity: 1;
  }

  .icon-float {
    animation: iconFloat 3s ease-in-out infinite;
  }

  @keyframes iconFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* Phone Items */
  .phone-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: rgba(240, 249, 255, 0.6);
    border-radius: 16px;
    border: 1px solid rgba(14, 165, 233, 0.1);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    animation: slideIn 0.5s ease-out forwards;
    animation-delay: var(--delay);
    opacity: 0;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .phone-item:hover {
    background: rgba(224, 242, 254, 0.8);
    border-color: rgba(14, 165, 233, 0.3);
    transform: translateX(8px);
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
  }

  .phone-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex: 1;
  }

  /* Email Item */
  .email-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: rgba(240, 253, 250, 0.6);
    border-radius: 16px;
    border: 1px solid rgba(20, 184, 166, 0.1);
    transition: all 0.3s;
  }

  .email-item:hover {
    background: rgba(204, 251, 241, 0.8);
    border-color: rgba(20, 184, 166, 0.3);
    transform: scale(1.02);
  }

  .email-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex: 1;
  }

  /* Copy Button */
  .copy-btn {
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(14, 165, 233, 0.2);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    opacity: 0;
  }

  .phone-item:hover .copy-btn,
  .email-item:hover .copy-btn {
    opacity: 1;
  }

  .copy-btn:hover {
    background: rgba(224, 242, 254, 1);
    border-color: rgba(14, 165, 233, 0.4);
    transform: scale(1.1) rotate(5deg);
  }

  .copy-btn:active {
    transform: scale(0.95) rotate(-5deg);
  }

  .check-icon {
    display: none;
    color: #10b981;
  }

  .copy-btn.copied .copy-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: block;
  }

  /* Address Card */
  .address-card {
    display: block;
    padding: 1.25rem;
    background: linear-gradient(135deg, rgba(240, 253, 250, 0.6), rgba(224, 242, 254, 0.6));
    border-radius: 20px;
    border: 2px solid rgba(20, 184, 166, 0.2);
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .address-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.1) 0%, transparent 70%);
    transition: transform 0.6s;
    transform: scale(0);
  }

  .address-card:hover::before {
    transform: scale(1);
  }

  .address-card:hover {
    border-color: rgba(14, 165, 233, 0.4);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(14, 165, 233, 0.2);
  }

  .pulse-icon {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.8;
    }
  }

  .map-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0891b2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .arrow-icon {
    transition: transform 0.3s;
  }

  .address-card:hover .arrow-icon {
    transform: translateX(5px);
  }

  /* Social Buttons */
  .social-btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem 0.75rem;
    background: rgba(255, 255, 255, 0.6);
    border: 2px solid rgba(139, 92, 246, 0.2);
    border-radius: 20px;
    text-decoration: none;
    color: #6366f1;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .social-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(139, 92, 246, 0.1));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .social-btn:hover::before {
    opacity: 1;
  }

  .social-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .social-btn:hover {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 12px 24px rgba(139, 92, 246, 0.2);
  }

  .social-btn.telegram:hover {
    background: linear-gradient(135deg, #0088cc, #0099dd);
    color: white;
    border-color: #0088cc;
  }

  .social-btn.facebook:hover {
    background: linear-gradient(135deg, #1877f2, #3b9eff);
    color: white;
    border-color: #1877f2;
  }

  .social-btn.instagram:hover {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white;
    border-color: #f09433;
  }

  .social-btn.youtube:hover {
    background: linear-gradient(135deg, #ff0000, #ff3333);
    color: white;
    border-color: #ff0000;
  }

  .social-btn.tiktok:hover {
    background: linear-gradient(135deg, #000000, #333333);
    color: white;
    border-color: #000000;
  }

  .social-btn.more-soon {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .social-btn.more-soon:hover {
    transform: none;
    box-shadow: none;
  }

  /* Info Banner */
  .info-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: linear-gradient(135deg, rgba(245, 243, 255, 0.8), rgba(238, 242, 255, 0.8));
    border-radius: 16px;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  /* CTA Banner */
  .cta-banner {
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.9),
      rgba(240, 249, 255, 0.9),
      rgba(224, 242, 254, 0.9)
    );
    backdrop-filter: blur(20px);
    border-radius: 32px;
    padding: 2.5rem;
    border: 2px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      0 20px 60px rgba(14, 165, 233, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    position: relative;
    overflow: hidden;
  }

  .cta-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 50%);
    animation: rotate 20s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #0ea5e9, #3b82f6);
    color: white;
    text-decoration: none;
    font-weight: 600;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(14, 165, 233, 0.3);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.2));
    transform: translateX(-100%);
    transition: transform 0.3s;
  }

  .cta-button:hover::before {
    transform: translateX(100%);
  }

  .cta-button:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 12px 32px rgba(14, 165, 233, 0.4);
  }

  .cta-button:active {
    transform: translateY(-2px) scale(1.02);
  }

  /* Toast Notification */
  .toast {
    position: fixed;
    top: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
    font-weight: 600;
    transform: translateY(-150%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1000;
  }

  .toast.show {
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cta-content {
      flex-direction: column;
      text-align: center;
    }

    .cta-button {
      width: 100%;
      justify-content: center;
    }

    .social-btn {
      padding: 1rem 0.5rem;
    }

    .social-label {
      font-size: 0.65rem;
    }
  }
</style>

<script>
  // Copy to clipboard functionality
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-btn');
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');

    copyButtons.forEach(button => {
      button.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();

        const textToCopy = button.getAttribute('data-copy');

        try {
          await navigator.clipboard.writeText(textToCopy || '');

          // Visual feedback on button
          button.classList.add('copied');
          setTimeout(() => {
            button.classList.remove('copied');
          }, 2000);

          // Show toast
          if (toast && toastMessage) {
            toastMessage.textContent = `Скопійовано: ${textToCopy}`;
            toast.classList.add('show');
            setTimeout(() => {
              toast.classList.remove('show');
            }, 3000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });

    // Add parallax effect to floating shapes
    document.addEventListener('mousemove', (e) => {
      const shapes = document.querySelectorAll('.floating-shape');
      const mouseX = e.clientX / window.innerWidth;
      const mouseY = e.clientY / window.innerHeight;

      shapes.forEach((shape, index) => {
        const speed = (index + 1) * 0.5;
        const x = (mouseX - 0.5) * speed * 50;
        const y = (mouseY - 0.5) * speed * 50;

        shape.style.transform = `translate(${x}px, ${y}px)`;
      });
    });

    // Add ripple effect on cards
    const cards = document.querySelectorAll('.glass-card');
    cards.forEach(card => {
      card.addEventListener('click', function(e) {
        const ripple = document.createElement('div');
        ripple.style.position = 'absolute';
        ripple.style.borderRadius = '50%';
        ripple.style.background = 'rgba(14, 165, 233, 0.3)';
        ripple.style.width = '20px';
        ripple.style.height = '20px';
        ripple.style.pointerEvents = 'none';

        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ripple.style.left = x + 'px';
        ripple.style.top = y + 'px';
        ripple.style.transform = 'translate(-50%, -50%) scale(0)';
        ripple.style.transition = 'transform 0.6s, opacity 0.6s';
        ripple.style.opacity = '1';

        card.appendChild(ripple);

        setTimeout(() => {
          ripple.style.transform = 'translate(-50%, -50%) scale(20)';
          ripple.style.opacity = '0';
        }, 10);

        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    });
  });
</script>

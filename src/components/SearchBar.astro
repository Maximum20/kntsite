---
import { doctors } from '../data'; 

const departments = ["Мегавольтна терапія", "Гамма-терапія", "Брахітерапія", "Близький фокус", "КТ-розмітка", "Реабілітація"];
const roles = ["Лікар з радіаційної онкології", "Лікар-рентгенолог", "Медичний фізик", "Медична сестра", "Старша медична сестра", "Інженер-програміст"];

const baseChip = "filter-chip px-4 py-2 md:px-5 md:py-2.5 bg-white border border-slate-200 rounded-xl text-[10px] md:text-xs font-bold text-slate-600 transition-all hover:border-slate-400 active:scale-95";
const activeChip = "filter-chip active bg-[#1a2b3b] border-[#1a2b3b] text-white shadow-lg shadow-slate-200 px-4 py-2 md:px-5 md:py-2.5 rounded-xl text-[10px] md:text-xs font-bold transition-all active:scale-95";
---

<!-- ДОДАНО relative z-[70], щоб випадаючий список був поверх карток -->
<div class="max-w-6xl mx-auto px-4 mb-12 relative z-[70]">
  <div class="backdrop-blur-2xl bg-white/70 border border-white/80 rounded-[2rem] md:rounded-[2.5rem] shadow-2xl shadow-slate-200/50 p-5 md:p-8">
    
    <!-- Пошуковий рядок -->
    <div class="relative mb-6">
      <div class="relative group">
        <input
          type="text"
          id="nameSearch"
          autocomplete="off"
          placeholder="Пошук за ім'ям або посадою..."
          class="w-full pl-5 pr-12 py-3.5 md:pl-7 md:pr-16 md:py-4 backdrop-blur-xl bg-white/90 border border-slate-200/60 rounded-2xl text-sm md:text-base font-medium text-slate-800 placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-4 focus:ring-slate-100 transition-all shadow-sm"
        />
        <div class="absolute right-4 md:right-6 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
          <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8" stroke-width="2.5"/><path d="M21 21l-4.35-4.35" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>
      </div>

      <!-- ВИПАДАЮЧИЙ СПИСОК (z-[100] для надійності) -->
      <div 
        id="searchDropdown" 
        class="hidden absolute left-0 right-0 top-full mt-3 max-h-[350px] overflow-y-auto z-[100] bg-white/95 backdrop-blur-xl border border-white/80 rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] custom-scrollbar"
      >
        <div id="dropdownResults" class="p-3 space-y-1">
          <!-- Результати рендерить JS -->
        </div>
      </div>
    </div>

    <button id="toggleAdvanced" class="flex items-center justify-center gap-2 mx-auto text-slate-600 hover:text-slate-900 font-bold text-xs md:text-sm transition-all group mb-2">
      <span>Розширені фільтри</span>
      <svg id="chevron" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>

    <div id="advancedPanel" class="hidden overflow-hidden pt-6 border-t border-slate-100 mt-4">
      <div class="space-y-6">
        <div>
          <label class="block text-[9px] md:text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 ml-1">Відділення</label>
          <div class="flex flex-wrap gap-2" id="deptFilter">
            <button class={activeChip} data-value="all">Всі</button>
            {departments.map(dept => <button class={baseChip} data-value={dept}>{dept}</button>)}
          </div>
        </div>
        <div>
          <label class="block text-[9px] md:text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 ml-1">Посада</label>
          <div class="flex flex-wrap gap-2" id="roleFilter">
            <button class={activeChip} data-value="all">Всі</button>
            {roles.map(role => <button class={baseChip} data-value={role}>{role}</button>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ doctors }}>
  function initFilters() {
    const searchInput = document.getElementById('nameSearch');
    const dropdown = document.getElementById('searchDropdown');
    const dropdownResults = document.getElementById('dropdownResults');
    const toggleBtn = document.getElementById('toggleAdvanced');
    const panel = document.getElementById('advancedPanel');
    const chevron = document.getElementById('chevron');
    const deptButtons = document.querySelectorAll('#deptFilter .filter-chip');
    const roleButtons = document.querySelectorAll('#roleFilter .filter-chip');

    let activeDept = 'all';
    let activeRole = 'all';

    const activeClasses = "bg-[#1a2b3b] border-[#1a2b3b] text-white shadow-lg shadow-slate-200";
    const baseClasses = "bg-white border-slate-200 text-slate-600 shadow-none";

    function applyFilters() {
      const query = searchInput.value.toLowerCase().trim();
      const cards = document.querySelectorAll('.doctor-card');
      const noResults = document.getElementById('noResults');
      let hasMatches = false;

      cards.forEach(card => {
        const name = card.dataset.name?.toLowerCase() || '';
        const role = card.dataset.role || '';
        const dept = card.dataset.dept || '';

        const matchesSearch = name.includes(query);
        const matchesDept = activeDept === 'all' || dept === activeDept;
        const matchesRole = activeRole === 'all' || role === activeRole;

        if (matchesSearch && matchesDept && matchesRole) {
          card.style.display = 'block';
          hasMatches = true;
        } else {
          card.style.display = 'none';
          card.classList.remove('is-expanded');
        }
      });
      if (noResults) noResults.classList.toggle('hidden', hasMatches);
    }

    function renderDropdown() {
      const query = searchInput.value.toLowerCase().trim();
      
      const filtered = doctors.filter(doc => {
        const nameMatch = (doc.name + " " + doc.surname).toLowerCase().includes(query);
        const deptMatch = activeDept === 'all' || doc.department === activeDept;
        const roleMatch = activeRole === 'all' || doc.role === activeRole;
        return nameMatch && deptMatch && roleMatch;
      });

      if (filtered.length === 0) {
        dropdown.classList.add('hidden');
        return;
      }

      dropdownResults.innerHTML = filtered.map(doc => `
        <div class="dropdown-item flex items-center gap-4 p-3 rounded-2xl hover:bg-slate-50 cursor-pointer transition-colors group" 
             data-fullname="${doc.name} ${doc.surname}">
          <div class="w-10 h-10 rounded-full overflow-hidden border border-slate-100 flex-shrink-0">
            <img src="${doc.image}" alt="${doc.name}" class="w-full h-full object-cover">
          </div>
          <div class="min-w-0">
            <div class="text-sm font-bold text-slate-900 leading-tight group-hover:text-[#1a365d]">${doc.name} ${doc.surname}</div>
            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest truncate">${doc.role}</div>
          </div>
        </div>
      `).join('');

      dropdown.classList.remove('hidden');

      document.querySelectorAll('.dropdown-item').forEach(item => {
        item.addEventListener('click', (e) => {
          searchInput.value = item.dataset.fullname;
          dropdown.classList.add('hidden');
          applyFilters();
          
          const targetCard = Array.from(document.querySelectorAll('.doctor-card'))
            .find(c => c.dataset.name === item.dataset.fullname);
          if (targetCard) {
            targetCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
            targetCard.click();
          }
        });
      });
    }

    searchInput.addEventListener('input', () => {
      applyFilters();
      renderDropdown();
    });

    searchInput.addEventListener('focus', renderDropdown);

    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add('hidden');
      }
    });

    toggleBtn?.addEventListener('click', () => {
      panel?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });

    function updateButtonStyles(buttons, activeBtn) {
      buttons.forEach(btn => {
        btn.classList.remove('active', ...activeClasses.split(' '));
        btn.classList.add(...baseClasses.split(' '));
      });
      activeBtn.classList.add('active', ...activeClasses.split(' '));
      activeBtn.classList.remove(...baseClasses.split(' '));
    }

    deptButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeDept = btn.dataset.value || 'all';
        updateButtonStyles(deptButtons, btn);
        applyFilters();
        if (document.activeElement === searchInput) renderDropdown();
      });
    });

    roleButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeRole = btn.dataset.value || 'all';
        updateButtonStyles(roleButtons, btn);
        applyFilters();
        if (document.activeElement === searchInput) renderDropdown();
      });
    });
  }

  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
  
  .dropdown-item:active {
    background-color: #f1f5f9;
    transform: scale(0.98);
  }
</style>
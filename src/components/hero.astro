---
import { Picture } from "astro:assets";
import heroImage from "@assets/main_page.jpg";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main class="max-w-screen-xl mx-auto px-5 pt-4 md:pt-20 pb-16 md:pb-32 font-sans relative overflow-visible">
  <div class="grid lg:grid-cols-[1fr_1.1fr] items-center gap-12 lg:gap-20 relative z-10">
    
    <div class="text-center lg:text-left order-1 relative z-10">
      <div class="inline-flex items-center gap-2 bg-cyan-50 text-cyan-600 px-3 py-1.5 rounded-full text-[10px] md:text-[11px] font-bold uppercase tracking-widest mb-6 border border-cyan-100 shadow-sm relative z-20">
        <Icon name="bx:bxs-badge-check" class="w-4 h-4" />
        Передові технології лікування
      </div>

      <h1 class="text-4xl lg:text-6xl xl:text-7xl font-bold leading-[1.1] tracking-tight text-slate-900 relative z-20">
        Відділення <br class="hidden lg:block"/> променевої терапії <br/> <span class="text-cyan-600 italic font-medium tracking-tighter">№1</span>
      </h1>

      <!-- МОБІЛЬНЕ ФОТО (Тепер теж клікабельне!) -->
      <div class="lg:hidden my-10 relative z-10">
         <div class="rounded-[2rem] overflow-hidden shadow-xl border-4 border-white bg-slate-50 relative z-10">
            <Picture
              src={heroImage}
              alt="Будівля відділення"
              widths={[400, 600]}
              sizes="100vw"
              loading="eager"
              format="avif"
              class="h-auto w-full object-cover" 
            />
         </div>
         <!-- Додав клас hug-card-trigger сюди -->
         <div class="hug-card-trigger absolute -bottom-6 -right-2 bg-white/95 backdrop-blur-md p-4 rounded-[1.5rem] shadow-2xl border border-slate-100 max-w-[180px] animate-float z-20 cursor-pointer active:scale-95">
            <div class="flex items-start gap-3 text-left pointer-events-none">
              <div class="w-10 h-10 shrink-0 bg-cyan-100 rounded-full flex items-center justify-center text-cyan-600 shadow-inner relative overflow-hidden">
                <div class="heart-layer absolute inset-0 flex items-center justify-center transition-all duration-300">
                  <Icon name="bx:bxs-heart" class="w-6 h-6" />
                </div>
                <div class="hug-layer absolute inset-0 flex items-center justify-center text-2xl opacity-0 scale-50 transition-all duration-300">
                  🤗
                </div>
              </div>
              <div>
                <h4 class="font-bold text-slate-900 text-base mb-1 tracking-tight leading-tight">Турбота про кожного</h4>
              <p class="text-[12px] text-slate-500 leading-relaxed font-medium">Індивідуальні плани лікування та підтримка на кожному етапі.</p>
              </div>
            </div>
          </div>
      </div>
      
      <p class="text-base md:text-lg mt-6 text-slate-600 max-w-xl mx-auto lg:mx-0 leading-relaxed font-medium relative z-20">
        Ми поєднуємо інноваційну радіотерапію з комплексним 
        блоком реабілітації для забезпечення найкращих 
        результатів та якості життя наших пацієнтів
      </p>
      
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start relative z-20">
        <Link
          href="/technologies"
          class="flex gap-2 items-center justify-center px-8 py-4 rounded-xl font-bold shadow-lg shadow-cyan-100 transition-transform active:scale-95"
          rel="noopener">
          <Icon class="text-white w-5 h-5" name="bx:bxs-zap" />
          Наші технології
        </Link>
        <Link
          style="outline"
          href="/contact"
          class="flex gap-2 items-center justify-center px-8 py-4 rounded-xl font-bold border-2 border-slate-200 hover:bg-slate-50 transition-all active:scale-95 text-slate-700">
          <Icon class="text-slate-700 w-5 h-5" name="bx:bxs-calendar" />
          Наші лікарі
        </Link>
      </div>

      <!-- ПАНЕЛЬ СТАТИСТИКИ -->
      <div class="mt-10 inline-flex items-center justify-between bg-white/40 backdrop-blur-md border border-white/60 py-3.5 px-8 md:py-4 md:px-12 rounded-[2.5rem] relative z-20 shadow-sm min-w-[280px] md:min-w-[400px]">
        <div class="flex flex-col text-left">
          <span class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tighter">15+</span>
          <span class="text-[9px] md:text-xs uppercase font-bold text-slate-500 tracking-widest mt-0.5">Років досвіду</span>
        </div>
        <div class="w-px h-10 bg-slate-300/60 mx-4"></div>
        <div class="flex flex-col text-left">
          <span class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tighter">2000+</span>
          <span class="text-[9px] md:text-xs uppercase font-bold text-slate-500 tracking-widest mt-0.5">Пацієнтів</span>
        </div>
      </div>
    </div>

    <!-- ПК ФОТО ТА КАРТКА -->
    <div class="hidden lg:block relative order-2 z-10 w-full">
      <div class="relative transform lg:scale-110 transition-transform duration-500 hover:scale-[1.17] group">
        
        <div class="rounded-[2.5rem] overflow-hidden shadow-2xl border-8 border-white bg-slate-50 relative z-10">
          <Picture
            src={heroImage}
            alt="Будівля відділення"
            widths={[800, 1200]}
            sizes="800px"
            loading="eager"
            format="avif"
            class="h-auto w-full object-cover" 
          />
        </div>

        <!-- Додав клас hug-card-trigger сюди -->
        <div class="hug-card-trigger absolute -bottom-10 -right-10 xl:-right-16 bg-white/95 backdrop-blur-md p-6 md:p-7 rounded-[2.5rem] shadow-2xl border border-slate-100 max-w-[280px] md:max-w-[320px] animate-float z-30 transition-all duration-300 cursor-pointer active:scale-95 select-none overflow-hidden">
          <div class="flex items-start gap-4 text-left pointer-events-none">
            <div class="w-12 h-12 shrink-0 bg-cyan-100 rounded-full flex items-center justify-center text-cyan-600 shadow-inner relative overflow-hidden">
              <div class="heart-layer absolute inset-0 flex items-center justify-center transition-all duration-300 opacity-100 scale-100">
                <Icon name="bx:bxs-heart" class="w-7 h-7" />
              </div>
              <div class="hug-layer absolute inset-0 flex items-center justify-center text-4xl opacity-0 scale-50 transition-all duration-300 leading-none">
                🤗
              </div>
            </div>
            <div class="pr-2">
              <h4 class="font-bold text-slate-900 text-base mb-1 tracking-tight leading-tight">Турбота про кожного</h4>
              <p class="text-[12px] text-slate-500 leading-relaxed font-medium">Індивідуальні плани лікування та підтримка на кожному етапі.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Шукаємо ВСІ картки (і мобільну, і ПК)
    const cards = document.querySelectorAll('.hug-card-trigger');

    cards.forEach(card => {
      const heart = card.querySelector('.heart-layer');
      const hug = card.querySelector('.hug-layer');

      if (heart && hug) {
        card.addEventListener('click', () => {
          // Анімація появи
          heart.style.opacity = '0';
          heart.style.transform = 'scale(0)';
          
          hug.style.opacity = '1';
          hug.style.transform = 'scale(1.4)';

          // Повернення
          setTimeout(() => {
            heart.style.opacity = '1';
            heart.style.transform = 'scale(1)';
            
            hug.style.opacity = '0';
            hug.style.transform = 'scale(0.5)';
          }, 1500);
        });
      }
    });
  });
</script>
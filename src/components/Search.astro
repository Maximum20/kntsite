---
import { Icon } from "astro-icon/components";

const searchIndex = [
  { title: "Мегавольтна терапія (Лінійні прискорювачі)", tags: ["лінійник", "linac", "електа", "elekta", "versa", "опромінення", "пухлина"], url: "/services/linac", category: "відділення" },
  { title: "КТ-розмітка (Симуляція)", tags: ["кт", "комп'ютерна томографія", "симуляція", "планування"], url: "/services/ct", category: "послуга" },
  { title: "Брахітерапія", tags: ["контактна променева терапія", "джерело", "іридій"], url: "/services/brachy", category: "відділення" },
  { title: "Діденко Олександр Петрович", tags: ["лікар", "радіолог", "онколог", "завідувач"], url: "/doctors", category: "лікар" },
  { title: "Контакти та графік роботи", tags: ["телефон", "адреса", "як доїхати", "головний лікар"], url: "#contacts", category: "інфо" }
];
---

{/* --- 1. КНОПКИ В ШАПЦІ --- */}
<div class="flex items-center gap-3 mr-2 xl:mr-6 xl:ml-4">
  
  {/* БУЛЬБАШКА СОЦМЕРЕЖ (Окремо) */}
  <div class="hidden xl:flex items-center gap-4 bg-white/60 p-2 px-4 rounded-full border border-slate-200/50 shadow-sm backdrop-blur-md transition-all hover:shadow-md hover:bg-white/80">
    <a href="#" class="text-slate-400 hover:text-blue-600 transition-all hover:scale-110"><Icon name="bx:bxl-facebook-circle" class="w-5 h-5" /></a>
    <a href="#" class="text-slate-400 hover:text-blue-400 transition-all hover:scale-110"><Icon name="bx:bxl-telegram" class="w-5 h-5" /></a>
    <a href="#" class="text-slate-400 hover:text-pink-500 transition-all hover:scale-110"><Icon name="bx:bxl-instagram" class="w-5 h-5" /></a>
  </div>

  {/* БУЛЬБАШКА ПОШУКУ З АНІМАЦІЄЮ ТЕКСТУ */}
  <div class="flex items-center">
    <button 
      id="search-trigger" 
      class="group relative flex items-center justify-start h-10 w-10 xl:hover:w-56 bg-blue-600 text-white rounded-full transition-all duration-500 ease-in-out overflow-hidden shadow-lg shadow-blue-500/20 active:scale-95"
    >
      {/* Іконка (Завжди зліва) */}
      <div class="flex items-center justify-center min-w-[40px] h-10">
        <Icon name="bx:bx-search" class="w-5 h-5" />
      </div>

      {/* Текст (З'являється при розширенні) */}
      <span class="whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-150 font-bold text-[13px] tracking-tight pr-6">
        Інтелектуальний пошук
      </span>

  
    </button>
  </div>
</div>

{/* --- 2. ВІКНО ПОШУКУ (MODAL) --- */}
<div id="search-modal" class="fixed inset-0 z-[999] hidden bg-slate-900/40 backdrop-blur-2xl items-start justify-center pt-12 md:pt-24 px-4 font-sans">
  <div class="bg-white w-full max-w-2xl rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.1)] overflow-hidden flex flex-col max-h-[80vh] border border-slate-100">
    
    {/* СУЧАСНІ ВКЛАДКИ (Segmented Control) */}
    <div class="p-4 bg-slate-50/50 border-b border-slate-100">
      <div class="relative flex bg-slate-200/50 p-1 rounded-xl">
        <button id="tab-offline" class="relative flex-1 py-2.5 text-xs font-bold uppercase tracking-wider transition-colors z-10 text-blue-600">Пошук</button>
        <button id="tab-ai" class="relative flex-1 py-2.5 text-xs font-bold uppercase tracking-wider transition-colors z-10 text-slate-500">AI Асистент</button>
        <div id="tab-indicator" class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-white rounded-lg shadow-sm transition-transform duration-300 ease-out"></div>
      </div>
    </div>

    <div class="p-6 md:p-8 flex flex-col flex-1 overflow-hidden">
      {/* Search Input */}
      <div class="relative flex items-center gap-4 bg-slate-50 px-6 py-4 rounded-2xl border border-slate-200 focus-within:border-blue-400 focus-within:ring-4 focus-within:ring-blue-50 transition-all flex-shrink-0">
        <Icon name="bx:bx-search" class="w-5 h-5 text-slate-400" />
        <input id="search-input" type="text" placeholder="Шукайте лікаря або відділення..." class="bg-transparent border-none outline-none w-full font-medium text-slate-700 placeholder:text-slate-400 text-base" autocomplete="off" />
        <div id="ai-loader" class="hidden">
           <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
      </div>
      
      {/* OFFLINE SECTION */}
      <div id="offline-content" class="mt-6 overflow-y-auto no-scrollbar transition-all duration-300">
        <div id="suggestions-box">
          <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-4 px-1">Швидкі посилання:</p>
          <div class="flex flex-wrap gap-2">
            {["#лікар", "#відділення", "лінійний прискорювач"].map(q => (
              <button class="tag-btn px-4 py-2 rounded-full bg-slate-100 text-slate-600 text-xs font-semibold hover:bg-blue-600 hover:text-white transition-all active:scale-95" data-query={q}>
                {q.replace('#', '')}
              </button>
            ))}
          </div>
        </div>

        <div id="results-list" class="mt-6 space-y-3 hidden">
          {/* JS Results */}
        </div>
      </div>

      {/* AI SECTION */}
      <div id="ai-content" class="mt-6 hidden flex flex-col flex-1 overflow-hidden transition-all duration-300 opacity-0 translate-x-4">
        <div id="chat-messages" class="flex-1 overflow-y-auto space-y-4 pr-2 mb-4 no-scrollbar min-h-[250px]">
          <div class="flex justify-start">
            <div class="bg-blue-50 text-blue-700 p-4 rounded-2xl rounded-tl-none text-sm max-w-[90%] leading-relaxed border border-blue-100">
              Вітаю! Я допоможу знайти потрібну інформацію. Що вас цікавить?
            </div>
          </div>
        </div>

        <div class="flex justify-between items-center px-1">
          <span class="text-[10px] text-slate-400 font-medium">Gemini 1.5 Flash</span>
          <button id="clear-chat" class="text-[10px] uppercase font-bold text-slate-400 hover:text-red-500 transition-colors">
            Очистити чат
          </button>
        </div>
      </div>
    </div>
  </div>
  <div id="search-close" class="fixed inset-0 -z-10 cursor-pointer"></div>
</div>

<script define:vars={{ searchIndex }}>
  // ТЕЛЕПОРТ (залишаємо без змін)
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('search-modal');
    if (modal) document.body.appendChild(modal);
  });

  const trigger = document.getElementById('search-trigger');
  const modal = document.getElementById('search-modal');
  const close = document.getElementById('search-close');
  const input = document.getElementById('search-input');
  
  const tOff = document.getElementById('tab-offline');
  const tAI = document.getElementById('tab-ai');
  const indicator = document.getElementById('tab-indicator');
  
  const cOff = document.getElementById('offline-content');
  const cAI = document.getElementById('ai-content');
  
  const resultsList = document.getElementById('results-list');
  const suggestionsBox = document.getElementById('suggestions-box');
  const chatMessages = document.getElementById('chat-messages');
  const clearChatBtn = document.getElementById('clear-chat');
  const aiLoader = document.getElementById('ai-loader');

  let currentTab = 'offline';
  let chatHistory = [];

  const switchToTab = (tab) => {
    currentTab = tab;
    if (tab === 'ai') {
      indicator.style.transform = 'translateX(100%)';
      tAI.classList.replace('text-slate-500', 'text-blue-600');
      tOff.classList.replace('text-blue-600', 'text-slate-500');
      cOff.classList.add('hidden');
      cAI.classList.remove('hidden');
      setTimeout(() => { cAI.style.opacity = '1'; cAI.style.transform = 'translateX(0)'; }, 10);
      input.placeholder = "Запитайте будь-що...";
    } else {
      indicator.style.transform = 'translateX(0)';
      tOff.classList.replace('text-slate-500', 'text-blue-600');
      tAI.classList.replace('text-blue-600', 'text-slate-500');
      cAI.classList.add('hidden');
      cOff.classList.remove('hidden');
      cAI.style.opacity = '0';
      cAI.style.transform = 'translateX(10px)';
      input.placeholder = "Шукайте лікаря або відділення...";
    }
    input.focus();
  };

  tOff?.addEventListener('click', () => switchToTab('offline'));
  tAI?.addEventListener('click', () => switchToTab('ai'));

  trigger?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    input?.focus();
    document.body.style.overflow = 'hidden';
  });

  const hideModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = 'auto';
  };
  close?.addEventListener('click', hideModal);

  function performSearch(query) {
    const rawQ = query.toLowerCase().trim();
    if (rawQ.length < 2) {
      resultsList?.classList.add('hidden');
      suggestionsBox?.classList.remove('hidden');
      return;
    }
    suggestionsBox?.classList.add('hidden');
    resultsList?.classList.remove('hidden');
    const filtered = searchIndex.filter(item => 
      item.title.toLowerCase().includes(rawQ) || item.tags.some(t => t.includes(rawQ))
    );
    renderResults(filtered);
  }

  function renderResults(results) {
    if (!resultsList) return;
    resultsList.innerHTML = results.length === 0 
      ? `<p class="text-sm text-slate-400 py-8 text-center">Нічого не знайдено</p>`
      : results.map(item => `
          <a href="${item.url}" class="group flex items-center justify-between p-4 rounded-xl bg-slate-50 hover:bg-blue-50 border border-transparent hover:border-blue-100 transition-all">
            <div class="flex flex-col">
              <span class="text-[9px] font-bold uppercase text-blue-500 tracking-tighter mb-0.5">${item.category}</span>
              <span class="font-semibold text-slate-700 group-hover:text-blue-700 transition-colors">${item.title}</span>
            </div>
            <div class="w-8 h-8 flex items-center justify-center rounded-full bg-white text-slate-300 group-hover:text-blue-600 shadow-sm transition-all">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="9 5l7 7-7 7" /></svg>
            </div>
          </a>
        `).join('');
  }

  function appendBubble(role, content) {
    const isAi = role === 'assistant';
    const div = document.createElement('div');
    div.className = `flex ${isAi ? 'justify-start' : 'justify-end'} animate-in fade-in slide-in-from-bottom-2`;
    div.innerHTML = `
      <div class="${isAi ? 'bg-slate-100 text-slate-700 rounded-tl-none border border-slate-200' : 'bg-blue-600 text-white rounded-tr-none shadow-md shadow-blue-100'} p-4 rounded-2xl text-sm max-w-[85%] leading-relaxed whitespace-pre-wrap">
        ${content}
      </div>
    `;
    chatMessages.appendChild(div);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return div.querySelector('div');
  }

  async function handleAiSearch() {
    const question = input.value.trim();
    if (!question) return;

    appendBubble('user', question);
    chatHistory.push({ role: 'user', content: question });
    
    input.value = "";
    input.disabled = true;
    aiLoader?.classList.remove('hidden');

    const aiBubble = appendBubble('assistant', "...");
    aiBubble.innerText = "";

    try {
      const response = await fetch('/api/chats', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: chatHistory }),
      });

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let fullResponse = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        fullResponse += decoder.decode(value, { stream: true });
        aiBubble.innerText = fullResponse;
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      chatHistory.push({ role: 'assistant', content: fullResponse });
    } catch (err) {
      aiBubble.innerText = "Помилка з'єднання.";
    } finally {
      aiLoader?.classList.add('hidden');
      input.disabled = false;
      input.focus();
    }
  }

  input?.addEventListener('input', (e) => {
    if (currentTab === 'offline') performSearch(e.target.value);
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && currentTab === 'ai') {
      e.preventDefault();
      handleAiSearch();
    }
  });

  clearChatBtn?.addEventListener('click', () => {
    chatHistory = [];
    chatMessages.innerHTML = `<div class="flex justify-start"><div class="bg-blue-50 text-blue-700 p-4 rounded-2xl rounded-tl-none text-sm max-w-[90%] border border-blue-100">Чат очищено. Чим я можу допомогти?</div></div>`;
  });

  document.querySelectorAll('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.getAttribute('data-query');
      input.value = q;
      if (currentTab === 'offline') performSearch(q);
      input.focus();
    });
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  #chat-messages { scroll-behavior: smooth; }
  input:focus { outline: none; }
</style>